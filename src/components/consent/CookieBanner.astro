---
/**
 * CookieBanner — Banner de consentimiento de cookies (RGPD/LOPDGDD)
 * Categorías:
 *   - analytics: GA4 + Microsoft Clarity
 *   - marketing: Meta Pixel + GoHighLevel CRM
 * Se muestra solo si no hay preferencias guardadas.
 */
---

<div
  id="cookie-banner"
  role="dialog"
  aria-modal="true"
  aria-label="Preferencias de cookies"
  class="fixed bottom-0 left-0 right-0 z-[9999] hidden"
>
  <div
    class="bg-foreground text-background border-t border-background/10 shadow-2xl"
  >
    <!-- Main banner -->
    <div
      id="cookie-banner-main"
      class="max-w-6xl mx-auto px-6 py-5 flex flex-col sm:flex-row items-start sm:items-center gap-4"
    >
      <div class="flex-1 min-w-0">
        <p class="text-sm font-semibold text-background mb-1">
          Este sitio usa cookies
        </p>
        <p class="text-xs text-background/70 leading-relaxed">
          Usamos cookies analíticas (Google Analytics, Microsoft Clarity) y de
          marketing (Meta Pixel) para mejorar la web y entender cómo nos
          encuentras. Las cookies técnicas son siempre activas.
          <a
            href="/cookies"
            class="underline text-background/80 hover:text-background ml-1"
            >Más información</a
          >
        </p>
      </div>
      <div class="flex flex-wrap gap-2 shrink-0">
        <button
          id="cookie-manage-btn"
          class="text-xs text-background/60 hover:text-background underline cursor-pointer transition-colors"
        >
          Gestionar
        </button>
        <button
          id="cookie-reject-btn"
          class="text-xs px-4 py-2 rounded-lg border border-background/30 text-background hover:bg-background/10 transition-colors cursor-pointer"
        >
          Solo necesarias
        </button>
        <button
          id="cookie-accept-btn"
          class="text-xs px-4 py-2 rounded-lg bg-background text-foreground font-semibold hover:bg-background/90 transition-colors cursor-pointer"
        >
          Aceptar todo
        </button>
      </div>
    </div>

    <!-- Granular panel (hidden by default) -->
    <div id="cookie-manage-panel" class="hidden border-t border-background/10">
      <div class="max-w-6xl mx-auto px-6 py-5">
        <p class="text-sm font-semibold text-background mb-4">
          Gestionar preferencias
        </p>
        <div class="grid sm:grid-cols-3 gap-4 mb-5">
          <!-- Necesarias -->
          <div class="bg-background/10 rounded-xl p-4">
            <div class="flex justify-between items-start mb-2">
              <p class="text-sm font-semibold text-background">Necesarias</p>
              <span
                class="text-xs text-background/60 bg-background/10 px-2 py-0.5 rounded-full"
                >Siempre activas</span
              >
            </div>
            <p class="text-xs text-background/60">
              Preferencias de tema (claro/oscuro). No recogen datos personales.
            </p>
          </div>
          <!-- Analíticas -->
          <div class="bg-background/10 rounded-xl p-4">
            <div class="flex justify-between items-start mb-2">
              <p class="text-sm font-semibold text-background">Analíticas</p>
              <label class="relative inline-flex items-center cursor-pointer">
                <input
                  type="checkbox"
                  id="consent-analytics"
                  class="sr-only peer"
                />
                <div
                  class="w-9 h-5 bg-background/20 peer-checked:bg-green-500 rounded-full transition-colors after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-4"
                >
                </div>
              </label>
            </div>
            <p class="text-xs text-background/60">
              Google Analytics (tráfico) y Microsoft Clarity (grabaciones de
              sesión anónimas).
            </p>
          </div>
          <!-- Marketing -->
          <div class="bg-background/10 rounded-xl p-4">
            <div class="flex justify-between items-start mb-2">
              <p class="text-sm font-semibold text-background">Marketing</p>
              <label class="relative inline-flex items-center cursor-pointer">
                <input
                  type="checkbox"
                  id="consent-marketing"
                  class="sr-only peer"
                />
                <div
                  class="w-9 h-5 bg-background/20 peer-checked:bg-green-500 rounded-full transition-colors after:content-[''] after:absolute after:top-0.5 after:left-0.5 after:bg-white after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:after:translate-x-4"
                >
                </div>
              </label>
            </div>
            <p class="text-xs text-background/60">
              Meta Pixel y seguimiento de campañas de publicidad.
            </p>
          </div>
        </div>
        <div class="flex gap-3 justify-end">
          <button
            id="cookie-save-btn"
            class="text-xs px-4 py-2 rounded-lg bg-background text-foreground font-semibold hover:bg-background/90 transition-colors cursor-pointer"
          >
            Guardar preferencias
          </button>
        </div>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function () {
    const STORAGE_KEY = "doscientos-consent";
    const banner = document.getElementById("cookie-banner");
    const managePanel = document.getElementById("cookie-manage-panel");

    function saveConsent(analytics, marketing) {
      const consent = {
        analytics: !!analytics,
        marketing: !!marketing,
        date: new Date().toISOString(),
      };
      localStorage.setItem(STORAGE_KEY, JSON.stringify(consent));
      window.__DOS_CONSENT = consent;
      banner.classList.add("hidden");
      loadTrackers(consent);
    }

    function loadTrackers(consent) {
      // Analytics: GA4
      if (consent.analytics && window.GA_MEASUREMENT_ID_PENDING) {
        const s = document.createElement("script");
        s.async = true;
        s.src =
          "https://www.googletagmanager.com/gtag/js?id=" +
          window.GA_MEASUREMENT_ID_PENDING;
        document.head.appendChild(s);
        window.dataLayer = window.dataLayer || [];
        function gtag() {
          dataLayer.push(arguments);
        }
        gtag("js", new Date());
        gtag("config", window.GA_MEASUREMENT_ID_PENDING, {
          page_path: window.location.pathname,
        });
      }
      // Analytics: Clarity
      if (consent.analytics && window.CLARITY_ID_PENDING) {
        (function (c, l, a, r, i, t, y) {
          c[a] =
            c[a] ||
            function () {
              (c[a].q = c[a].q || []).push(arguments);
            };
          t = l.createElement(r);
          t.async = 1;
          t.src = "https://www.clarity.ms/tag/" + i;
          y = l.getElementsByTagName(r)[0];
          y.parentNode.insertBefore(t, y);
        })(window, document, "clarity", "script", window.CLARITY_ID_PENDING);
      }
      // Marketing: Meta Pixel
      if (consent.marketing && window.META_PIXEL_ID_PENDING) {
        !(function (f, b, e, v, n, t, s) {
          if (f.fbq) return;
          n = f.fbq = function () {
            n.callMethod
              ? n.callMethod.apply(n, arguments)
              : n.queue.push(arguments);
          };
          if (!f._fbq) f._fbq = n;
          n.push = n;
          n.loaded = !0;
          n.version = "2.0";
          n.queue = [];
          t = b.createElement(e);
          t.async = !0;
          t.src = v;
          s = b.getElementsByTagName(e)[0];
          s.parentNode.insertBefore(t, s);
        })(
          window,
          document,
          "script",
          "https://connect.facebook.net/en_US/fbevents.js",
        );
        fbq("init", window.META_PIXEL_ID_PENDING);
        fbq("track", "PageView");
      }
      // Marketing: GoHighLevel
      if (consent.marketing && window.GHL_TRACKING_ID_PENDING) {
        const s = document.createElement("script");
        s.src = "https://link.msgsndr.com/js/external-tracking.js";
        s.dataset.trackingId = window.GHL_TRACKING_ID_PENDING;
        document.body.appendChild(s);
      }
    }

    // Show banner only if no consent stored
    if (!window.__DOS_CONSENT) {
      banner.classList.remove("hidden");
    }

    document
      .getElementById("cookie-accept-btn")
      .addEventListener("click", function () {
        saveConsent(true, true);
      });

    document
      .getElementById("cookie-reject-btn")
      .addEventListener("click", function () {
        saveConsent(false, false);
      });

    document
      .getElementById("cookie-manage-btn")
      .addEventListener("click", function () {
        managePanel.classList.toggle("hidden");
        const stored = window.__DOS_CONSENT;
        if (stored) {
          document.getElementById("consent-analytics").checked =
            stored.analytics;
          document.getElementById("consent-marketing").checked =
            stored.marketing;
        }
      });

    document
      .getElementById("cookie-save-btn")
      .addEventListener("click", function () {
        const analytics = document.getElementById("consent-analytics").checked;
        const marketing = document.getElementById("consent-marketing").checked;
        saveConsent(analytics, marketing);
      });
  })();
</script>
