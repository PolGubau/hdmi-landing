---
/**
 * FoundingMembers - Oferta exclusiva de lanzamiento
 * Solo para los primeros clientes
 */
import Button from "../ui/Button.astro";

// Configuración de plazas (actualizar manualmente cuando consigas clientes)
const FOUNDING_SLOTS_TOTAL = 5;
const FOUNDING_SLOTS_TAKEN = 2; // ⚠️ ACTUALIZA ESTO
const FOUNDING_SLOTS_LEFT = FOUNDING_SLOTS_TOTAL - FOUNDING_SLOTS_TAKEN;
---

<section
  class="landing-section bg-primary text-background overflow-hidden relative py-20 md:rounded-4xl mx-auto mb-20"
>
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-10">
    <div
      class="absolute inset-0"
      style="background-image: radial-gradient(circle at 2px 2px, currentColor 1px, transparent 0); background-size: 24px 24px;"
    >
    </div>
  </div>

  <div class="relative max-w-4xl mx-auto text-center" data-stagger="100">
    <!-- Urgency badge -->
    <div
      class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-background/10 backdrop-blur-sm border border-background/20 mb-8"
      data-reveal="scale"
      data-speed="fast"
      data-easing="bounce"
    >
      <span class="relative flex size-3">
        <span
          class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"
        ></span>
        <span class="relative inline-flex rounded-full size-3 bg-green-400"
        ></span>
      </span>
      <span
        class="text-sm font-medium"
        🎟️
        Founding
        Members
        ·
        Solo
        {FOUNDING_SLOTS_LEFT}
        de
        {FOUNDING_SLOTS_TOTAL}
        plazas
        <
        span
      >
      </span>

      <!-- Main heading -->
      <h2
        class="text-3xl md:text-5xl font-bold mb-4 tracking-tight"
        data-reveal="scale"
        data-speed="normal"
        data-easing="bounce"
      >
        Únete como Founding Member
      </h2>

      <!-- Subheading -->
      <p
        class="text-lg md:text-xl mb-8 opacity-90 max-w-2xl mx-auto"
        data-reveal="bottom"
        data-speed="normal"
        data-easing="soft"
        data-distance="small"
      >
        Acabamos de lanzar doscientos. Los primeros {FOUNDING_SLOTS_TOTAL} clientes
        obtienen beneficios exclusivos de por vida.
      </p>

      <!-- Benefits -->
      <div
        class="grid md:grid-cols-3 gap-6 mb-10 max-w-3xl mx-auto"
        data-stagger="100"
      >
        <div
          class="flex flex-col items-center gap-2 p-4 rounded-lg bg-background/10 backdrop-blur-sm"
          data-reveal="bottom"
          data-speed="normal"
          data-easing="soft"
        >
          <svg
            class="size-8 mb-2"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
            ></path>
          </svg>
          <p class="font-semibold">20% descuento</p>
          <p class="text-sm opacity-75">En todos tus proyectos</p>
        </div>

        <div
          class="flex flex-col items-center gap-2 p-4 rounded-lg bg-background/10 backdrop-blur-sm"
          data-reveal="bottom"
          data-speed="normal"
          data-easing="soft"
        >
          <svg
            class="size-8 mb-2"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
          <p class="font-semibold">Prioridad VIP</p>
          <p class="text-sm opacity-75">Soporte prioritario siempre</p>
        </div>

        <div
          class="flex flex-col items-center gap-2 p-4 rounded-lg bg-background/10 backdrop-blur-sm"
          data-reveal="bottom"
          data-speed="normal"
          data-easing="soft"
        >
          <svg
            class="size-8 mb-2"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <p class="font-semibold">Inicio inmediato</p>
          <p class="text-sm opacity-75">Empezamos esta semana</p>
        </div>
      </div>

      <!-- What we ask -->
      <div
        class="mb-10 p-6 rounded-xl bg-background/10 backdrop-blur-sm border border-background/20 max-w-2xl mx-auto"
        data-reveal="bottom"
        data-speed="normal"
        data-easing="soft"
      >
        <p class="text-sm font-semibold mb-3">A cambio, te pedimos:</p>
        <ul class="text-sm space-y-2 opacity-90 text-left">
          <li>✓ Feedback honesto durante el desarrollo</li>
          <li>✓ Permiso para usar tu proyecto como caso de estudio</li>
          <li>✓ Testimonial si estás satisfecho con el resultado</li>
        </ul>
      </div>

      <!-- CTA -->
      <div
        data-reveal="scale"
        data-speed="fast"
        data-easing="elastic"
        class="flex justify-center flex-col items-center"
      >
        <a href="/contact" class="w-auto">
          <Button
            size="lg"
            withArrow
            class="bg-background text-foreground hover:bg-background/90"
          >
            Reservar mi plaza de Founding Member
          </Button>
        </a>
        <p class="text-sm opacity-75 mt-4">
          ⏰ Solo {FOUNDING_SLOTS_LEFT}
          {FOUNDING_SLOTS_LEFT === 1 ? "plaza" : "plazas"} restantes
        </p>
      </div>
    </div>
  </div>
</section>
