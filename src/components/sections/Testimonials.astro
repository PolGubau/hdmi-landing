---
import { Image } from "astro:assets";
import { Check, StarIcon } from "@lucide/astro";
import SectionHeader from "../ui/SectionHeader.astro";

import carlosImg from "~/assets/media/testimonials/carlos-ruiz.webp";
import michaelImg from "~/assets/media/testimonials/michael-schmidt.webp";
import sofiaImg from "~/assets/media/testimonials/sofia-martinez.webp";

const siteUrl = "https://doscientos.es";

const testimonials = [
  {
    quote:
      "No solo programan - entienden de producto. Nos ayudaron a priorizar lo que importaba y en 6 semanas teníamos 500+ usuarios y €50K en funding.",
    author: "Sofia Martínez",
    role: "CEO",
    company: "Exchange Student",
    project: "Flatmatch",
    rating: 5,
    metrics: "500+ usuarios · €50K funding · ROI 300%",
    highlight: "De 0 a 500+ usuarios en 3 meses",
    image: sofiaImg,
  },
  {
    quote:
      "Nadie se atrevía a tocar nuestro sistema de 15 años. doscientos lo migró sin parar el negocio ni un minuto. Cero downtime, +40% de rendimiento.",
    author: "Michael Schmidt",
    role: "CTO",
    company: "IFCO Systems",
    project: "IFCO Recollections",
    rating: 5,
    metrics: "0 downtime · +40% rendimiento · €30K/año ahorrados",
    highlight: "Migración crítica sin interrupciones",
    image: michaelImg,
  },
  {
    quote:
      "De 3 horas a 15 minutos. El sistema se pagó solo en 2 meses. Y cuando tenemos dudas, responden en el día.",
    author: "Carlos Ruiz",
    role: "Director técnico",
    company: "Bitácora",
    project: "Bitácora ERP",
    rating: 5,
    metrics: "€15K/mes ahorrados · ROI en 2 meses · -90% tiempo",
    highlight: "Automatización con ROI del 600%",
    image: carlosImg,
  },
];
---

<section class="landing-section bg-accent/5">
  <SectionHeader
    title="Lo que dicen nuestros clientes"
    description="Resultados reales de empresas que confiaron en nosotros"
    tag="Testimonios"
    align="center"
  />

  <div
    class="grid md:grid-cols-3 gap-4 max-w-6xl mx-auto w-full"
    data-stagger="100"
  >
    {
      testimonials.map((testimonial, i) => {
        const isFeatured = i === 1;
        return (
          <div
            class={`testimonial-card rounded-2xl p-8 flex flex-col gap-4 ${
              isFeatured
                ? "bg-foreground text-background shadow-xl md:-translate-y-4 md:scale-[1.02] z-10"
                : "bg-background border border-muted shadow-pastel"
            }`}
            data-reveal="bottom"
            data-speed="normal"
            data-easing="soft"
          >
            {/* Rating */}
            <div class="flex gap-0">
              {Array.from({ length: testimonial.rating }).map(() => (
                <StarIcon
                  class="size-5 text-yellow-400"
                  fill="currentColor"
                  stroke="currentColor"
                />
              ))}
            </div>

            {/* Highlight badge */}
            <div
              class={`inline-flex items-center gap-2 px-3 py-1 rounded-md w-fit text-xs font-semibold ${
                isFeatured
                  ? "bg-background/15 text-background"
                  : "bg-primary/10 text-primary"
              }`}
            >
              <Check class="size-3" />
              {testimonial.highlight}
            </div>

            {/* Quote */}
            <blockquote
              class={`leading-relaxed flex-1 ${isFeatured ? "text-background/90" : "text-foreground"}`}
            >
              "{testimonial.quote}"
            </blockquote>

            {/* Metrics */}
            <div
              class={`px-4 py-3 rounded-lg border mb-3 ${
                isFeatured
                  ? "border-background/20 bg-background/10"
                  : "border-muted"
              }`}
            >
              <p
                class={`text-sm font-semibold ${isFeatured ? "text-background/70" : "text-muted-foreground"}`}
              >
                {testimonial.metrics}
              </p>
            </div>

            {/* Author */}
            <div
              class={`flex items-start gap-3 pt-2 border-t ${isFeatured ? "border-background/20" : "border-muted"}`}
            >
              <Image
                src={testimonial.image}
                alt={testimonial.author}
                width={40}
                height={40}
                class="size-10 rounded-full object-cover object-top mt-2 shrink-0"
              />
              <div class="mt-2">
                <p
                  class={`font-semibold ${isFeatured ? "text-background" : "text-foreground"}`}
                >
                  {testimonial.author}
                </p>
                <p
                  class={`text-xs ${isFeatured ? "text-background/60" : "text-muted-foreground"}`}
                >
                  {testimonial.role}, {testimonial.company}
                </p>
                <p
                  class={`text-xs mt-1 ${isFeatured ? "text-background/60" : "text-muted-foreground"}`}
                >
                  Proyecto: {testimonial.project}
                </p>
              </div>
            </div>
          </div>
        );
      })
    }
  </div>

  {/* Trust indicators */}
  <div
    class="flex flex-wrap justify-center items-center gap-8 text-sm text-muted-foreground"
    data-reveal="bottom"
    data-speed="normal"
    data-easing="soft"
  >
    <div class="flex items-center gap-2">
      <Check class="size-5 text-green-500" />
      <span>100% de clientes satisfechos</span>
    </div>
    <div class="flex items-center gap-2">
      <Check class="size-5 text-green-500" />

      <span>Proyectos entregados a tiempo</span>
    </div>
    <div class="flex items-center gap-2">
      <Check class="size-5 text-green-500" />

      <span>Soporte post-lanzamiento incluido</span>
    </div>
  </div>
</section>

<!-- Schema.org Review agregado -->
<script
  is:inline
  type="application/ld+json"
  set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    name: "doscientos",
    url: siteUrl,
    aggregateRating: {
      "@type": "AggregateRating",
      ratingValue: "5",
      bestRating: "5",
      worstRating: "1",
      reviewCount: String(testimonials.length),
    },
    review: testimonials.map((t) => ({
      "@type": "Review",
      reviewRating: {
        "@type": "Rating",
        ratingValue: String(t.rating),
        bestRating: "5",
      },
      author: {
        "@type": "Person",
        name: t.author,
        jobTitle: t.role,
        worksFor: {
          "@type": "Organization",
          name: t.company,
        },
      },
      reviewBody: t.quote,
      name: t.highlight,
    })),
  })}
/>
