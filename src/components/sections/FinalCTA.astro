---
import { copy } from "~/lib/copy";
import { branding } from "~/config/branding";

const { finalCta } = copy;
---

<section id="final-cta" class="py-32 px-6">
  <div class="max-w-4xl mx-auto text-center space-y-12">
    <!-- Question -->
    <h2
      class="text-4xl md:text-6xl font-bold text-neutral-900 dark:text-neutral-50"
    >
      {finalCta.question}
    </h2>

    <!-- Description -->
    <div class="space-y-4 text-xl md:text-2xl text-neutral-600 dark:text-neutral-400">
      {
        finalCta.description.map((line) => (
          <p>{line}</p>
        ))
      }
    </div>

    <!-- CTA Button -->
    <div class="pt-8">
      <a
        href={`https://wa.me/${branding.contact.whatsapp.number}?text=${encodeURIComponent(branding.contact.whatsapp.defaultMessage)}`}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 px-10 py-5 bg-neutral-900 dark:bg-neutral-50 text-neutral-50 dark:text-neutral-900 rounded-full font-bold text-xl hover:scale-105 transition-transform duration-300 shadow-xl hover:shadow-2xl"
      >
        {finalCta.cta}
        <svg
          class="w-6 h-6"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
        </svg>
      </a>
    </div>

    <!-- Alternative contact -->
    <div class="pt-8 text-neutral-500 dark:text-neutral-400">
      <p class="text-sm">
        O escríbenos a{" "}
        <a
          href={`mailto:${branding.contact.email}`}
          class="underline hover:text-neutral-900 dark:hover:text-neutral-50 transition-colors"
        >
          {branding.contact.email}
        </a>
      </p>
    </div>
  </div>
</section>

