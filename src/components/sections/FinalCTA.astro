---
import { branding } from "~/config/branding";
import { copy } from "~/lib/copy";
import AvailableTag from "../ui/AvailableTag.astro";
import CtaButton from "../ui/CtaButton.astro";
import SectionTag from "../ui/SectionTag.astro";
import ClientsMarqueeRail from "../ui/clients/ClientsMarqueeRail.astro";

const { finalCta } = copy;
---

<section id="final-cta" class="px-6">
  <div
    class="max-w-3xl mx-auto text-center flex flex-col justify-center items-center overflow-hidden gap-10"
  >
    <SectionTag>Agenda una llamada</SectionTag>

    <h2
      class="text-2xl lg:text-4xl font-bold text-balance tracking-tight text-foreground"
    >
      {finalCta.question}
    </h2>

    <!-- Description -->
    <div class="text-muted-foreground max-w-sm text-pretty">
      {finalCta.description}
    </div>
    <ClientsMarqueeRail />
    <CtaButton />
    <AvailableTag />
  </div>
</section>
