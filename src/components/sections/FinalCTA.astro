---
import { branding } from "~/config/branding";
import { copy } from "~/shared/lib/copy";
import AvailableTag from "../ui/AvailableTag.astro";
import CtaButton from "../ui/CtaButton.astro";
import SectionTag from "../ui/SectionTag.astro";
import ClientsMarqueeRail from "../ui/clients/ClientsMarqueeRail.astro";

const { finalCta } = copy;
---

<section id="final-cta" class="px-6">
  <div
    class="max-w-3xl w-full mx-auto text-center flex flex-col justify-center items-center gap-10"
    data-stagger="100"
  >
    <div data-reveal="top" data-speed="fast" data-easing="smooth">
      <SectionTag>Agenda una llamada</SectionTag>
    </div>

    <h2
      class="text-2xl lg:text-4xl font-bold text-balance tracking-tight text-foreground"
      data-reveal="scale"
      data-speed="normal"
      data-easing="bounce"
    >
      {finalCta.question}
    </h2>

    <!-- Description -->
    <div
      class="text-muted-foreground max-w-sm text-pretty"
      data-reveal="bottom"
      data-speed="normal"
      data-easing="soft"
      data-distance="small"
    >
      {finalCta.description}
    </div>
  </div>

  <!-- Marquee fuera del contenedor max-w para que ocupe todo el ancho -->
  <div
    class="w-full"
    data-reveal="scale"
    data-speed="fast"
    data-easing="smooth"
  >
    <ClientsMarqueeRail />
  </div>

  <!-- Volver al contenedor centrado -->
  <div
    class="max-w-3xl w-full mx-auto text-center flex flex-col justify-center items-center gap-10"
  >
    <div data-reveal="scale" data-speed="fast" data-easing="elastic">
      <CtaButton />
    </div>

    <div data-reveal="bottom" data-speed="normal" data-easing="soft">
      <AvailableTag />
    </div>
  </div>
</section>
