---
import { copy } from "~/lib/copy";

const { whatWeDo } = copy;
---

<section id="what-we-do" class="py-32 px-6 bg-neutral-50 dark:bg-neutral-900">
  <div class="max-w-5xl mx-auto space-y-16">
    <!-- Header -->
    <div class="space-y-4">
      <h2
        class="text-4xl md:text-6xl font-bold text-neutral-900 dark:text-neutral-50"
      >
        {whatWeDo.title}
      </h2>
      <p class="text-2xl md:text-3xl text-neutral-600 dark:text-neutral-400">
        {whatWeDo.subtitle}
      </p>
    </div>

    <!-- Services grid -->
    <ul class="grid md:grid-cols-2 gap-6">
      {
        whatWeDo.services.map((service, index) => (
          <li class="group relative p-6 rounded-2xl bg-white dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 hover:border-neutral-900 dark:hover:border-neutral-50 transition-all duration-300 hover:shadow-lg">
            <div class="flex items-start gap-4">
              <span class="flex-shrink-0 w-8 h-8 flex items-center justify-center rounded-full bg-neutral-900 dark:bg-neutral-50 text-neutral-50 dark:text-neutral-900 font-bold text-sm">
                {index + 1}
              </span>
              <p class="text-lg md:text-xl text-neutral-700 dark:text-neutral-300 leading-relaxed">
                {service}
              </p>
            </div>
          </li>
        ))
      }
    </ul>

    <!-- Footer -->
    <div class="flex items-center justify-between pt-12 border-t border-neutral-200 dark:border-neutral-800">
      <p class="text-2xl md:text-3xl font-semibold text-neutral-900 dark:text-neutral-50">
        {whatWeDo.footer}
      </p>
      <span
        class="text-4xl md:text-5xl font-bold text-neutral-900 dark:text-neutral-50"
      >
        {whatWeDo.badge}
      </span>
    </div>
  </div>
</section>

