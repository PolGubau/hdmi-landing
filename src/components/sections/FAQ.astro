---
import SectionHeader from "../ui/SectionHeader.astro";

const faqs = [
  {
    question: "¿Qué servicios ofrecéis?",
    answer:
      "Estamos especializados en crear productos digitales a medida: diseño UX/UI, desarrollo web y móvil, branding, automatización de procesos y más. Nos adaptamos a lo que tu proyecto necesite.",
  },
  {
    question: "¿Trabajáis con startups o solo con empresas grandes?",
    answer:
      "Trabajamos con todo tipo de empresas, desde startups hasta compañías consolidadas. Lo importante es que tengas un proyecto claro y ganas de crecer.",
  },
  {
    question: "¿Cuánto suele durar un proyecto?",
    answer:
      "Depende del alcance, pero normalmente de 2 a 8 semanas. Proyectos más complejos pueden extenderse, pero siempre trabajamos con plazos claros desde el inicio.",
  },
  {
    question: "¿Podéis ayudar solo con una parte del proyecto?",
    answer:
      "Sí, podemos encargarnos solo de una fase: diseño, desarrollo, branding o lo que necesites. No hace falta que contrates el paquete completo.",
  },
  {
    question: "¿Cómo es vuestra estructura de precios?",
    answer:
      "Adaptamos el presupuesto al proyecto. Siempre enviamos una propuesta clara antes de empezar, sin sorpresas ni costes ocultos.",
  },
  {
    question: "¿Ofrecéis soporte después de entregar el proyecto?",
    answer:
      "Sí. Podemos seguir colaborando con mantenimiento, mejoras o nuevos desarrollos. Muchos clientes trabajan con nosotros de forma recurrente.",
  },
  {
    question: "¿Usáis WordPress, Wix o plantillas?",
    answer:
      "Desarrollamos a medida porque tu negocio es único. Las plantillas limitan tu crecimiento y rendimiento. Nuestro código es 3x más rápido, 100% escalable y se adapta exactamente a tus necesidades. Sin limitaciones técnicas, sin plugins innecesarios, sin sorpresas.",
  },
  {
    question: "¿Qué pasa si necesito cambios después del lanzamiento?",
    answer:
      "Ofrecemos soporte continuo y muchos clientes trabajan con nosotros de forma recurrente. Respondemos en menos de 24h y podemos implementar cambios rápidamente. También te entregamos documentación completa para que tu equipo pueda hacer ajustes menores.",
  },
  {
    question: "¿Cómo garantizáis que el proyecto se entregue a tiempo?",
    answer:
      "Trabajamos con sprints semanales y entregas incrementales. Ves el progreso cada semana y puedes dar feedback continuo. Si hay algún retraso, te avisamos inmediatamente con un plan de acción. Transparencia total, sin sorpresas de última hora.",
  },
];
---

<section id="faq" class="landing-section">
  <SectionHeader
    tag="Preguntas frecuentes"
    title="¿Tienes dudas?"
    subtitle="Las resolvemos."
    description="Todo lo que necesitas saber sobre cómo trabajamos y entregamos resultados."
    align="center"
  />

  <div class="max-w-2xl w-full mx-auto" data-stagger="80">
    {
      faqs.map((faq) => (
        <details
          class="group border-b border-border py-4"
          data-reveal="bottom"
          data-speed="normal"
          data-easing="smooth"
          data-distance="small"
        >
          <summary class="flex justify-between items-center cursor-pointer list-none p-2">
            <h3 class="text-lg font-semibold text-foreground pr-8">
              {faq.question}
            </h3>
            <svg
              class="size-5 text-muted-foreground transition-transform group-open:rotate-180 shrink-0"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M19 9l-7 7-7-7"
              />
            </svg>
          </summary>
          <p class="mt-4 text-muted-foreground leading-relaxed pb-4">
            {faq.answer}
          </p>
        </details>
      ))
    }
  </div>

  <script define:vars={{ faqs }}>
    // Schema.org FAQ structured data - Generado automáticamente desde el array de FAQs
    const faqSchema = {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      mainEntity: faqs.map((faq) => ({
        "@type": "Question",
        name: faq.question,
        acceptedAnswer: {
          "@type": "Answer",
          text: faq.answer,
        },
      })),
    };

    const script = document.createElement("script");
    script.type = "application/ld+json";
    script.text = JSON.stringify(faqSchema);
    document.head.appendChild(script);
  </script>
</section>
