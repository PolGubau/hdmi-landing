---
import ContactForm from "../forms/ContactForm";
import AvailableTag from "../ui/AvailableTag.astro";

const spotsLeft = 2;
const nextMonth = new Date(
  Date.now() + 30 * 24 * 60 * 60 * 1000,
).toLocaleString("es-ES", { month: "long" });
---

<section
  class="landing-section bg-primary text-background overflow-hidden relative py-14 lg:rounded-4xl lg:max-w-[90vw] mx-auto mb-20"
>
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-10">
    <div
      class="absolute inset-0"
      style="background-image: radial-gradient(circle at 2px 2px, currentColor 1px, transparent 0); background-size: 24px 24px;"
    >
    </div>
  </div>

  <div class="relative max-w-4xl mx-auto text-center" data-stagger="100">
    <!-- Urgency badge -->
    <AvailableTag />

    <!-- Main heading -->
    <h2
      class="text-4xl md:text-5xl font-bold mb-6 tracking-tight"
      data-reveal="scale"
      data-speed="normal"
      data-easing="bounce"
    >
      Cuéntanos tu proyecto
    </h2>

    <!-- Subheading -->
    <p
      class="text-xl md:text-2xl mb-4 opacity-90"
      data-reveal="bottom"
      data-speed="normal"
      data-easing="soft"
      data-distance="small"
    >
      Te respondemos en menos de 24 horas
    </p>

    <p
      class="opacity-75 mb-12 max-w-md mx-auto"
      data-easing="soft"
      data-distance="small"
    >
      Sin compromiso. Te damos feedback honesto y un plan de acción claro,
      aunque al final no trabajemos juntos.
    </p>

    <!-- Formulario embebido -->
    <div
      class="bg-background rounded-2xl p-8 text-left mb-12 shadow-xl"
      data-reveal="bottom"
      data-speed="normal"
      data-easing="soft"
    >
      <ContactForm client:load />
    </div>

    <!-- Guarantees -->
    <div
      class="grid md:grid-cols-3 gap-6 pt-12 border-t border-background/20"
      data-stagger="80"
    >
      <div
        class="flex flex-col items-center gap-3"
        data-reveal="bottom"
        data-speed="normal"
        data-easing="soft"
      >
        <div
          class="size-12 rounded-full bg-background/10 flex items-center justify-center"
        >
          <svg
            class="size-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>
        <p class="font-semibold">Respuesta en 24h</p>
        <p class="text-sm opacity-75">
          Te respondemos siempre en menos de un día hábil
        </p>
      </div>

      <div
        class="flex flex-col items-center gap-3"
        data-reveal="bottom"
        data-speed="normal"
        data-easing="soft"
      >
        <div
          class="size-12 rounded-full bg-background/10 flex items-center justify-center"
        >
          <svg
            class="size-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
            ></path>
          </svg>
        </div>
        <p class="font-semibold">Sin compromiso</p>
        <p class="text-sm opacity-75">
          Feedback honesto aunque no trabajemos juntos
        </p>
      </div>

      <div
        class="flex flex-col items-center gap-3"
        data-reveal="bottom"
        data-speed="normal"
        data-easing="soft"
      >
        <div
          class="size-12 rounded-full bg-background/10 flex items-center justify-center"
        >
          <svg
            class="size-6"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
        </div>
        <p class="font-semibold">Lanzamiento rápido</p>
        <p class="text-sm opacity-75">De idea a producto en 6-8 semanas</p>
      </div>
    </div>
  </div>
</section>
