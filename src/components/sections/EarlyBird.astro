---
/**
 * EarlyBird - Oferta limitada para crear urgencia
 */
import Button from "../ui/Button.astro";

// Calcular días restantes hasta fin de mes
const today = new Date();
const endOfMonth = new Date(today.getFullYear(), today.getMonth() + 1, 0);
const daysLeft = Math.ceil(
  (endOfMonth.getTime() - today.getTime()) / (1000 * 60 * 60 * 24),
);
const monthLabel = today.toLocaleDateString("es-ES", { month: "long" });
---

<section
  class="landing-section bg-primary text-background overflow-hidden relative py-20 md:rounded-4xl max-w-[90vw] mx-auto mb-20"
>
  <!-- Background pattern -->
  <div class="absolute inset-0 opacity-10">
    <div
      class="absolute inset-0"
      style="background-image: radial-gradient(circle at 2px 2px, currentColor 1px, transparent 0); background-size: 24px 24px;"
    >
    </div>
  </div>

  <div class="relative max-w-4xl mx-auto text-center" data-stagger="100">
    <!-- Urgency badge -->
    <div
      class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-background/10 backdrop-blur-sm border border-background/20 mb-8"
      data-reveal="scale"
      data-speed="fast"
      data-easing="bounce"
    >
      <span class="relative flex size-3">
        <span
          class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"
        ></span>
        <span class="relative inline-flex rounded-full size-3 bg-green-400"
        ></span>
      </span>
      <span class="text-sm font-medium"
        >Oferta válida solo {daysLeft} días más</span
      >
    </div>

    <!-- Main heading -->
    <h2
      class="text-3xl md:text-5xl font-bold mb-4 tracking-tight"
      data-reveal="scale"
      data-speed="normal"
      data-easing="bounce"
    >
      15% de descuento en proyectos de {monthLabel}
    </h2>

    <!-- Subheading -->
    <p
      class="text-lg md:text-xl mb-8 opacity-90 max-w-2xl mx-auto"
      data-reveal="bottom"
      data-speed="normal"
      data-easing="soft"
      data-distance="small"
    >
      Reserva tu proyecto ahora y ahorra hasta 3.000€. Solo 2 slots disponibles.
    </p>

    <!-- Benefits -->
    <div
      class="grid md:grid-cols-3 gap-6 mb-10 max-w-3xl mx-auto"
      data-stagger="100"
    >
      <div
        class="flex flex-col items-center gap-2 p-4 rounded-lg bg-background/10 backdrop-blur-sm"
        data-reveal="bottom"
        data-speed="normal"
        data-easing="soft"
      >
        <svg
          class="size-8 mb-2"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
          ></path>
        </svg>
        <p class="font-semibold">15% descuento</p>
        <p class="text-sm opacity-75">En el precio total</p>
      </div>

      <div
        class="flex flex-col items-center gap-2 p-4 rounded-lg bg-background/10 backdrop-blur-sm"
        data-reveal="bottom"
        data-speed="normal"
        data-easing="soft"
      >
        <svg
          class="size-8 mb-2"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
        </svg>
        <p class="font-semibold">Inicio inmediato</p>
        <p class="text-sm opacity-75">Empezamos en 1 semana</p>
      </div>

      <div
        class="flex flex-col items-center gap-2 p-4 rounded-lg bg-background/10 backdrop-blur-sm"
        data-reveal="bottom"
        data-speed="normal"
        data-easing="soft"
      >
        <svg
          class="size-8 mb-2"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
          ></path>
        </svg>
        <p class="font-semibold">Garantía total</p>
        <p class="text-sm opacity-75">Si no estás satisfecho, no pagas</p>
      </div>
    </div>

    <!-- CTA -->
    <div
      data-reveal="scale"
      data-speed="fast"
      data-easing="elastic"
      class="flex justify-center flex-col items-center"
    >
      <a href="/contact" class="w-auto">
        <Button
          size="lg"
          withArrow
          class="bg-background text-foreground hover:bg-background/90"
        >
          Reservar mi descuento ahora
        </Button>
      </a>
      <p class="text-sm opacity-75 mt-4">
        ⏰ Oferta válida hasta el {
          endOfMonth.toLocaleDateString("es-ES", {
            day: "numeric",
            month: "long",
          })
        }
      </p>
    </div>
  </div>
</section>
