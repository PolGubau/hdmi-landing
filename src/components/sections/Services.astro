---
import { Code, Database, Palette, Smartphone } from "@lucide/astro";
import Image from "astro/components/Image.astro";
import SectionHeader from "~/components/ui/SectionHeader.astro";
import CtaButton from "../ui/CtaButton.astro";

import imageMobile from "~/assets/media/landing/flatmatch-mobile.webp";
import imageFooter from "~/assets/media/landing/nh-admin.webp";
import imagePhones from "~/assets/media/landing/phones.webp";

const services = [
  {
    title: "Interfaces que reducen fricción operativa",
    description:
      "Sistemas internos, dashboards y herramientas que tu equipo realmente usa. Diseñados para acelerar decisiones, no para impresionar en demos.",
  },
  {
    title: "MVPs que validan con usuarios reales, no prototipos de Figma",
    description:
      "Priorizamos las funcionalidades que generan aprendizaje real. Lanzamos en semanas para que tus usuarios, no tus suposiciones, decidan qué construir a continuación.",
  },
  {
    title: "Automatizaciones que eliminan trabajo manual repetitivo",
    description:
      "Si tu equipo gestiona datos en Excel, coordina por email o repite los mismos pasos cada semana, hay una automatización esperando. ROI medible en meses.",
  },
  {
    title: "Modernización de sistemas legacy sin parar las operaciones",
    description:
      "Migramos plataformas críticas que frenan el crecimiento de tu empresa. Sin downtime, sin pérdida de datos, sin sorpresas.",
  },
  {
    title: "Arquitectura técnica para los próximos 5 años",
    description: "No para el siguiente sprint",
  },
];

const benefits = [
  {
    label: "Precio fijo",
    icon: Code,
  },
  {
    label: "Entrega en 6 semanas",
    icon: Palette,
  },
  {
    label: "Demo semanal",
    icon: Smartphone,
  },
  {
    label: "Código 100% tuyo",
    icon: Database,
  },
  {
    label: "Sin lock-in",
    icon: Code,
  },
  {
    label: "Senior desde día 1",
    icon: Palette,
  },
];
---

<section class="landing-section">
  <SectionHeader
    title="Problemas de negocio"
    subtitle="que resolvemos con software."
    description="No hacemos webs. Construimos sistemas que operan en producción y generan ROI medible."
    tag="Servicios"
  />

  <!-- bento con stagger -->
  <ul
    class="bento flex flex-col lg:grid grid-cols-3 auto-rows-auto gap-4 w-full"
    data-stagger="120"
  >
    <li
      class="row-span-2 panel gap-4 grid grid-rows-[auto_1fr]"
      data-reveal="top-left"
      data-speed="normal"
      data-easing="smooth"
    >
      <header class="flex flex-col gap-4">
        <h3>{services[0].title}</h3>
        <p>{services[0].description}</p>
      </header>
      <div class="relative w-full h-full overflow-hidden max-h-[360px]">
        <Image
          width={800}
          height={650}
          src={imagePhones}
          alt="Captura de pantalla del panel de administración de NovaHair, mostrando un diseño limpio y moderno con gráficos de rendimiento y gestión de clientes."
          class="w-full h-full object-cover object-top"
        />

        <div
          class="absolute bottom-0 left-0 w-full h-12 bg-gradient-to-t from-accent"
        >
        </div>
      </div>
      <li
        class="col-span-2 panel flex flex-col justify-between gap-4"
        data-reveal="top-right"
        data-speed="normal"
        data-easing="smooth"
      >
        <header class="flex flex-col gap-4">
          <h3>{services[1].title}</h3>
          <p>{services[1].description}</p>
        </header>
        {
          benefits && (
            <ul class="flex gap-2 flex-wrap max-w-md">
              {benefits.map((step) => {
                const IconComponent = step.icon;
                return (
                  <li class="py-1.5 px-3 bg-muted text-sm rounded-full flex gap-2 items-center text-foreground">
                    <IconComponent class="size-3.5" />
                    {step.label}
                  </li>
                );
              })}
            </ul>
          )
        }
      </li>
      <li
        class="col-span-2 col-start-2 row-start-2 panel"
        data-reveal="right"
        data-speed="normal"
        data-easing="smooth"
      >
        <div class="grid lg:grid-cols-[2fr_1fr] gap-4 h-full">
          <div class="flex flex-col justify-between gap-6">
            <header class="flex flex-col gap-4">
              <h3>{services[2].title}</h3>
              <p>{services[2].description}</p>
            </header>
            <CtaButton size="sm" />
          </div>
          <div class="relative w-full flex items-end justify-end">
            <Image
              width={500}
              height={900}
              src={imageMobile}
              alt="Captura de pantalla del panel de administración de NovaHair, mostrando un diseño limpio y moderno con gráficos de rendimiento y gestión de clientes."
              class="w-full max-h-[200px] border-4 border-b-0 border-primary bg-[#c7c7c7] p-1 rounded-t-[32px] object-cover object-top"
            />

            <div
              class="absolute bottom-0 left-0 w-full h-12 bg-gradient-to-t from-accent"
            >
            </div>
          </div>
        </div>
      </li>
      <li
        class="col-span-2 row-start-3 panel"
        data-reveal="bottom-left"
        data-speed="normal"
        data-easing="smooth"
      >
        <h3>{services[3].title}</h3>
        <p>{services[3].description}</p>
        <div class="relative w-full h-full">
          <Image
            width={900}
            height={300}
            src={imageFooter}
            alt="Captura de pantalla del panel de administración de NovaHair, mostrando un diseño limpio y moderno con gráficos de rendimiento y gestión de clientes."
            class="w-full max-w-[700px] h-[110px] mt-4 border border-muted p-2 rounded-2xl object-cover object-top"
          />

          <div
            class="absolute bottom-0 left-0 w-full h-12 bg-gradient-to-t from-accent"
          >
          </div>
        </div>
      </li>
      <li
        class="flex flex-col gap-4 bg-linear-60 from-primary/20 to-primary/30 rounded-2xl shadow-pastel p-7 justify-end"
        data-reveal="bottom-right"
        data-speed="normal"
        data-easing="bounce"
      >
        <header class="h-full flex flex-col justify-end">
          <h3 class="text-2xl font-semibold text-pretty">
            {services[4].title}
          </h3>
          <p class="text-xl">{services[4].description}</p>
        </header>
        <CtaButton />
      </li>
    </li>
  </ul>
</section>
