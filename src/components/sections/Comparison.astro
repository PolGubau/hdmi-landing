---
import SectionHeader from "../ui/SectionHeader.astro";
import SectionTag from "../ui/SectionTag.astro";

const rows = [
  { label: "Tiempo de entrega", us: "6 semanas", them: "4-6 meses" },
  { label: "Precio", us: "Precio fijo acordado", them: "Presupuesto variable" },
  { label: "Pagos", us: "Por hitos (30/40/30)", them: "Por adelantado" },
  {
    label: "Comunicación",
    us: "Demo semanal + Slack",
    them: "Reuniones mensuales",
  },
  {
    label: "Propiedad del código",
    us: "100% tuyo",
    them: "Depende del contrato",
  },
  {
    label: "Soporte post-lanzamiento",
    us: "30 días incluidos",
    them: "Coste adicional",
  },
  {
    label: "Flexibilidad",
    us: "Cambios en 24-48h",
    them: "Change requests formales",
  },
  { label: "Equipo", us: "Senior dedicado", them: "Junior + rotación" },
];
---

<section id="faq" class="landing-section">
  <SectionHeader
    tag="Comparativa"
    title="Agencia tradicional"
    subtitle="vs doscientos"
    description="No somos una agencia tradicional. Somos un equipo pequeño, rápido y especializado en lanzar productos que funcionan."
    align="center"
  />

  <div
    role="table"
    aria-label="Comparativa doscientos vs agencia tradicional"
    class="rounded-2xl overflow-hidden border border-muted"
    data-reveal="bottom"
    data-speed="normal"
    data-easing="soft"
  >
    <!-- Header -->
    <div role="rowgroup">
      <div role="row" class="grid grid-cols-3 bg-foreground text-background">
        <div role="columnheader" class="p-4 text-sm font-semibold">
          <span class="sr-only">Criterio</span>
        </div>
        <div
          role="columnheader"
          class="p-4 text-sm font-semibold text-center border-l border-background/20"
        >
          doscientos
        </div>
        <div
          role="columnheader"
          class="p-4 text-sm font-semibold text-center border-l border-background/20 opacity-60"
        >
          Agencia tradicional
        </div>
      </div>
    </div>

    <!-- Rows -->
    <div role="rowgroup">
      {
        rows.map((row, i) => (
          <div
            role="row"
            class={`grid grid-cols-3 border-t border-muted ${i % 2 === 0 ? "bg-background" : "bg-accent/40"}`}
          >
            <div
              role="rowheader"
              class="p-4 text-sm font-medium text-muted-foreground"
            >
              {row.label}
            </div>
            <div
              role="cell"
              class="p-4 text-sm font-semibold text-primary text-center border-l border-muted flex items-center justify-center gap-2"
            >
              <span aria-hidden="true" class="text-green-500">
                ✓
              </span>
              {row.us}
            </div>
            <div
              role="cell"
              class="p-4 text-sm text-muted-foreground text-center border-l border-muted flex items-center justify-center gap-2"
            >
              <span aria-hidden="true" class="text-red-400">
                ✗
              </span>
              {row.them}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
