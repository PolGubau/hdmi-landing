---
import { StarIcon } from "@lucide/astro";
import { copy } from "~/shared/lib/copy";
import AvailableTag from "../ui/AvailableTag.astro";
import Button from "../ui/Button.astro";
import ClientsCarousel from "./ClientsCarousel.astro";
import ProjectsCarousel from "./ProjectsCarousel.astro";

const { hero } = copy;
---

<section
  id="hero"
  class="relative flex flex-col gap-10 justify-center px-6 pt-20 items-center"
>
  <AvailableTag />

  <!-- Main title con bounce impactante -->
  <h1
    data-reveal="scale"
    data-speed="fast"
    data-easing="bounce"
    data-delay="100"
    class="text-2xl max-w-2xl text-center md:text-5xl font-semibold tracking-tight text-foreground"
  >
    {hero.title}
  </h1>

  <!-- Subtitle suave desde abajo -->
  <div
    data-reveal="bottom"
    data-speed="normal"
    data-easing="soft"
    data-delay="300"
    data-distance="small"
    class="text-muted-foreground max-w-xl text-center lg:text-lg"
  >
    {hero.subtitle}
  </div>

  <!-- CTA con escala elástica -->
  <div
    data-reveal="scale"
    data-speed="fast"
    data-easing="elastic"
    data-delay="500"
    class="pt-4 flex flex-col items-center gap-4"
  >
    <div class="flex flex-wrap gap-4 justify-center">
      <a href={`/contact`} id="hero-cta-primary">
        <Button withArrow>
          {hero.cta}
        </Button>
      </a>
      <a href="/projects" id="hero-cta-secondary">
        <Button variant="outline">Ver proyectos</Button>
      </a>
    </div>

    <script is:inline>
      ["hero-cta-primary", "hero-cta-secondary"].forEach((id) => {
        document.getElementById(id)?.addEventListener("click", () => {
          if ("gtag" in window) {
            window.gtag("event", "cta_click", {
              event_category: "engagement",
              event_label: id,
            });
          }
        });
      });
    </script>

    <!-- Social proof -->
    <div
      class="flex items-center gap-5 text-sm text-muted-foreground"
      data-reveal="bottom"
      data-speed="normal"
      data-easing="soft"
      data-delay="700"
    >
      <div class="flex items-center gap-2">
        <div class="flex -space-x-2">
          <div
            class="size-8 rounded-full bg-muted border-2 border-background flex items-center justify-center text-xs font-bold text-primary"
          >
            L
          </div>
          <div
            class="size-8 rounded-full bg-muted border-2 border-background flex items-center justify-center text-xs font-bold text-primary"
          >
            M
          </div>
          <div
            class="size-8 rounded-full bg-muted border-2 border-background flex items-center justify-center text-xs font-bold text-primary"
          >
            C
          </div>
        </div>
        <span>+21 clientes satisfechos</span>
      </div>
      <div class="flex items-center gap-2">
        <div class="flex items-center gap-1 max-lg:hidden">
          {
            new Array(5)
              .fill(0)
              .map(() => (
                <StarIcon
                  class="size-5 text-yellow-400"
                  fill="currentColor"
                  stroke="currentColor"
                />
              ))
          }
        </div>
        <span class="text-foreground">5/5</span>
        <StarIcon
          class="size-5 text-yellow-400 lg:hidden"
          fill="currentColor"
          stroke="currentColor"
        />
      </div>
    </div>
  </div>

  <ProjectsCarousel />
  <ClientsCarousel />
</section>
