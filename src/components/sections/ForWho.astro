---
import { CircleCheck, CircleX } from "@lucide/astro";
import SectionHeader from "../ui/SectionHeader.astro";

const fits = [
  "Tienes un proceso manual que tu equipo repite cada semana",
  "Quieres lanzar un MVP y validar antes de contratar un equipo interno",
  "Tu sistema actual frena el crecimiento - legacy, Excel, integraciones rotas",
  "Necesitas resultados en semanas, no en trimestres",
  "Valoras la transparencia: precio fijo, código tuyo, sin lock-in",
];

const doesntFit = [
  "Buscas la opción más barata del mercado",
  "No tienes claro el problema que el software tiene que resolver",
  "Necesitas un recurso externo para ejecutar instrucciones, no un equipo con criterio",
  "Tu proyecto puede esperar más de 6 meses",
];
---

<section class="landing-section">
  <SectionHeader
    tag="Para quién"
    title="Somos el equipo adecuado"
    subtitle="si reconoces esto"
    description="Trabajamos con un número limitado de clientes para garantizar dedicación real. Antes de empezar, nos aseguramos de que encajamos."
    align="center"
  />

  <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto w-full">
    <!-- Fit -->
    <div
      class="panel flex flex-col gap-5"
      data-reveal="left"
      data-speed="normal"
      data-easing="smooth"
    >
      <h3 class="font-semibold text-foreground flex items-center gap-2">
        <CircleCheck class="size-5 text-green-500 shrink-0" />
        Encajamos bien si…
      </h3>
      <ul class="flex flex-col gap-3">
        {
          fits.map((item) => (
            <li class="flex items-start gap-3 text-sm text-muted-foreground">
              <CircleCheck
                class="size-4 text-green-500 shrink-0 mt-0.5"
                aria-hidden="true"
              />
              {item}
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Doesn't fit -->
    <div
      class="panel flex flex-col gap-5 bg-muted/40 p-4 rounded-xl"
      data-reveal="right"
      data-speed="normal"
      data-easing="smooth"
    >
      <h3 class="font-semibold text-foreground flex items-center gap-2">
        <CircleX class="size-5 text-muted-foreground shrink-0" />
        Probablemente no si…
      </h3>
      <ul class="flex flex-col gap-3">
        {
          doesntFit.map((item) => (
            <li class="flex items-start gap-3 text-sm text-muted-foreground">
              <CircleX
                class="size-4 text-muted-foreground shrink-0 mt-0.5"
                aria-hidden="true"
              />
              {item}
            </li>
          ))
        }
      </ul>
      <p
        class="text-xs text-muted-foreground/70 mt-auto pt-4 border-t border-muted"
      >
        Si no encajamos, te decimos a quién acudir. Sin rodeos.
      </p>
    </div>
  </div>
</section>
