---
import { copy } from "~/lib/copy";

const { method } = copy;
---

<section id="method" class="py-32 px-6 bg-white dark:bg-neutral-950">
  <div class="max-w-6xl mx-auto">
    <!-- Header -->
    <div class="max-w-2xl mb-20">
      <h2
        class="text-4xl md:text-5xl font-semibold text-[#0f1115] dark:text-neutral-50 mb-4"
        style="letter-spacing: -0.03em;"
      >
        {method.title}
      </h2>
      <p
        class="text-lg text-[#50576b] dark:text-neutral-400"
        style="letter-spacing: -0.02em;"
      >
        {method.subtitle}
      </p>
    </div>

    <!-- Steps with progress bar -->
    <div class="relative">
      <!-- Progress bar (fixed on desktop) -->
      <div class="hidden lg:block absolute left-0 top-0 bottom-0 w-px">
        <div class="sticky top-32 h-screen">
          <div class="relative h-64">
            <!-- Background line -->
            <div
              class="absolute left-0 top-0 w-px h-full bg-neutral-200 dark:bg-neutral-800"
            >
            </div>
            <!-- Progress line (will be animated with JS) -->
            <div
              id="progress-line"
              class="absolute left-0 top-0 w-px bg-[#0f1115] dark:bg-neutral-50 transition-all duration-300"
              style="height: 0%"
            >
            </div>
          </div>
        </div>
      </div>

      <!-- Steps -->
      <div class="lg:pl-16 space-y-24">
        {
          method.steps.map((step, index) => (
            <div class="method-step group" data-step={index}>
              <div class="space-y-6">
                {/* Number badge */}
                <div class="inline-flex items-center gap-3">
                  <div class="w-10 h-10 flex items-center justify-center rounded-full bg-[#f9fafb] dark:bg-neutral-900 border border-neutral-200 dark:border-neutral-800 text-[#0f1115] dark:text-neutral-50 font-semibold text-sm">
                    {step.number}
                  </div>
                  <span class="text-sm font-medium text-[#50576b] dark:text-neutral-400 uppercase tracking-wider">
                    Paso {step.number}
                  </span>
                </div>

                {/* Content */}
                <div class="space-y-4">
                  <h3
                    class="text-3xl md:text-4xl font-semibold text-[#0f1115] dark:text-neutral-50"
                    style="letter-spacing: -0.03em;"
                  >
                    {step.title}
                  </h3>
                  <p
                    class="text-lg text-[#50576b] dark:text-neutral-400 leading-relaxed max-w-2xl"
                    style="letter-spacing: -0.02em;"
                  >
                    {step.description}
                  </p>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<script>
  // Animate progress bar on scroll
  function updateProgressBar() {
    const progressLine = document.getElementById("progress-line");
    const methodSection = document.getElementById("method");
    const steps = document.querySelectorAll(".method-step");

    if (!progressLine || !methodSection || steps.length === 0) return;

    const sectionTop = methodSection.offsetTop;
    const sectionHeight = methodSection.offsetHeight;
    const scrollPosition = window.scrollY + window.innerHeight / 2;

    // Calculate progress (0 to 100)
    const progress = Math.max(
      0,
      Math.min(100, ((scrollPosition - sectionTop) / sectionHeight) * 100),
    );

    progressLine.style.height = `${progress}%`;
  }

  // Update on scroll
  window.addEventListener("scroll", updateProgressBar);
  window.addEventListener("resize", updateProgressBar);

  // Initial update
  updateProgressBar();
</script>
