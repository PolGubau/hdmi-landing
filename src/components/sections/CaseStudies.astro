---
import SectionHeader from "~/components/ui/SectionHeader.astro";
import ProjectsRail from "~/features/projects/ui/ProjectsRail.astro";
import { getProjects } from "~/shared/lib/collections";

const projects = await getProjects(4);
---

<section
  id="cases"
  class="px-6 max-w-5xl overflow-x-hidden mx-auto space-y-16 w-full"
>
  <SectionHeader
    tag="Nuestro trabajo"
    title="Cómo hemos ayudado a otras empresas"
    description="Descubre cómo hemos ayudado a nuestros clientes a convertir ideas ambiciosas en productos digitales impactantes."
    linkText="Ver todos"
    linkHref="/projects"
  />

  <ProjectsRail projects={projects} />
</section>
