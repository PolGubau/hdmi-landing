---
import SectionHeader from "~/components/ui/SectionHeader.astro";
import ProjectCard from "../ui/ProjectCard.astro";
import { getProjects } from "~/shared/lib/collections";

const projects = await getProjects()
---

<section id="cases" class="px-6 max-w-7xl mx-auto space-y-16 w-full">
  <SectionHeader
    tag="Nuestro trabajo"
    title="Cómo hemos ayudado a otras empresas"
    description="Descubre cómo hemos ayudado a nuestros clientes a convertir ideas ambiciosas en productos digitales impactantes."
    linkText="Ver todos"
    linkHref="/projects"
  />

  <!-- Cases grid con stagger alternado -->
  <div class="grid lg:grid-cols-2 gap-6" data-stagger="150">
    {
      projects.map((project, index: number) => (
        <div
          data-reveal={index % 2 === 0 ? "left" : "right"}
          data-speed="normal"
          data-easing="smooth"
        >
          <ProjectCard
            id={project.id}
            title={project.data.title}
            summary={project.data.summary}
            services_provided={project.data.services_provided ?? []}
            color={project.data.color}
            cover={project.data.cover}
          />
        </div>
      ))
    }
  </div>
</section>
