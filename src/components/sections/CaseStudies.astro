---
import SectionHeader from "~/components/ui/SectionHeader.astro";
import { copy } from "~/lib/copy";

const { cases } = copy;
---

<section id="cases" class="py-32 px-6 bg-white dark:bg-neutral-950">
  <div class="max-w-7xl mx-auto space-y-16">
    <SectionHeader
      label="Nuestro trabajo"
      title="Cómo hemos ayudado a otras empresas"
      description="Descubre cómo hemos ayudado a nuestros clientes a convertir ideas ambiciosas en productos digitales impactantes."
      linkText="Ver todos"
      linkHref="/proyectos"
    />

    <!-- Cases grid -->
    <div class="grid lg:grid-cols-2 gap-8">
      {
        cases.items.map((caseItem) => (
          <article class="group p-8 rounded-2xl bg-white dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 hover:border-neutral-900 dark:hover:border-neutral-50 transition-all duration-300 hover:shadow-xl space-y-6">
            {/* Client name */}
            <div class="space-y-2">
              <h3 class="text-2xl md:text-3xl font-bold text-neutral-900 dark:text-neutral-50">
                {caseItem.client}
              </h3>
              <p class="text-lg text-neutral-600 dark:text-neutral-400 font-medium">
                {caseItem.subtitle}
              </p>
            </div>

            {/* Description */}
            <p class="text-base md:text-lg text-neutral-700 dark:text-neutral-300 leading-relaxed">
              {caseItem.description}
            </p>

            {/* Results */}
            <div class="pt-6 border-t border-neutral-200 dark:border-neutral-700">
              <p class="text-sm font-semibold text-neutral-500 dark:text-neutral-400 uppercase tracking-wider mb-4">
                Resultado:
              </p>
              <ul class="space-y-3">
                {caseItem.results.map((result) => (
                  <li class="flex items-start gap-3">
                    <svg
                      class="flex-shrink-0 w-5 h-5 mt-0.5 text-green-600 dark:text-green-400"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M5 13l4 4L19 7"
                      />
                    </svg>
                    <span class="text-neutral-700 dark:text-neutral-300">
                      {result}
                    </span>
                  </li>
                ))}
              </ul>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
