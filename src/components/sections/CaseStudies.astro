---
import SectionHeader from "~/components/ui/SectionHeader.astro";
import ProjectsRail from "~/features/projects/ui/ProjectsRail.astro";
import { getProjects } from "~/shared/lib/collections";

const projects = await getProjects(4);
---

<section id="cases" class="landing-section">
  <SectionHeader
    tag="Nuestro trabajo"
    title="Proyectos que están en producción"
    description="MVPs lanzados, sistemas migrados y automatizaciones activas. Nombres reales, métricas reales."
    linkText="Ver todos"
    linkHref="/projects"
  />

  <ProjectsRail projects={projects} />
</section>
