---
import { copy } from "~/lib/copy";

const { problem } = copy;
---

<section id="problem" class="py-32 px-6 bg-neutral-50 dark:bg-neutral-900">
  <div class="max-w-4xl mx-auto space-y-16">
    <!-- Title -->
    <div class="space-y-4">
      <h2
        class="text-4xl md:text-6xl font-bold text-neutral-900 dark:text-neutral-50"
      >
        {problem.title}
      </h2>
      <p class="text-2xl md:text-3xl text-neutral-600 dark:text-neutral-400">
        {problem.subtitle}
      </p>
    </div>

    <!-- Problems list -->
    <ul class="space-y-6">
      {
        problem.points.map((point) => (
          <li class="flex items-start gap-4 group">
            <span class="flex-shrink-0 w-2 h-2 mt-3 rounded-full bg-red-500 group-hover:scale-150 transition-transform duration-300" />
            <span class="text-xl md:text-2xl text-neutral-700 dark:text-neutral-300">
              {point}
            </span>
          </li>
        ))
      }
    </ul>

    <!-- Conclusion -->
    <div class="pt-12 space-y-2 border-t border-neutral-200 dark:border-neutral-800">
      {
        problem.conclusion.map((line) => (
          <p class="text-2xl md:text-3xl font-semibold text-neutral-900 dark:text-neutral-50">
            {line}
          </p>
        ))
      }
    </div>
  </div>
</section>

