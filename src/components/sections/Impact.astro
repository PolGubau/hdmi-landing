---
import StatCard from "~/components/ui/StatCard.astro";
import SectionHeader from "../ui/SectionHeader.astro";

const stats = [
  {
    number: "500+",
    label: "Usuarios en 3 meses — sin invertir en ads",
    description:
      "Flatmatch pasó de 0 a 500 usuarios orgánicos en su primer trimestre. Cuando el producto resuelve un problema real, los usuarios lo recomiendan solos.",
  },
  {
    number: "-90%",
    label: "Menos tiempo en procesos manuales",
    description:
      "Bitácora pasó de 3 horas procesando pedidos a 15 minutos automáticos. El sistema se pagó solo en 2 meses.",
  },
  {
    number: "€0",
    label: "Downtime en una migración de 1M+ registros",
    description:
      "IFCO Systems tenía un sistema legacy de 15 años. Lo migramos a arquitectura moderna sin parar el negocio ni un minuto.",
  },
];
---

<section class="landing-section">
  <SectionHeader
    title="Resultados de proyectos"
    subtitle="que ya están en producción"
    align="center"
    tag="Impacto"
  />
  <!-- Bento Grid -->
  <div
    data-stagger="150"
    class="gap-4 grid grid-cols-[repeat(auto-fit,minmax(250px,1fr))] w-full"
  >
    {
      stats.map((stat) => (
        <StatCard
          number={stat.number}
          label={stat.label}
          description={stat.description}
        />
      ))
    }
  </div>
</section>
