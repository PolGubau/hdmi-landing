---
import StatCard from "~/components/ui/StatCard.astro";
import SectionHeader from "../ui/SectionHeader.astro";

const stats = [
  {
    number: "500+",
    label: "Usuarios conseguidos sin ads",
    description:
      "Nuestros clientes generan tracción orgánica desde el primer día. Cuando el producto funciona, los usuarios lo recomiendan.",
  },
  {
    number: "-90%",
    label: "Reducción en tiempo de procesos",
    description:
      "De 3 horas manuales a 15 minutos automáticos. Automatizaciones que generan ROI real en meses, no años.",
  },
  {
    number: "x5",
    label: "Crecimiento promedio de usuarios",
    description:
      "Productos diseñados para escalar. Nuestros clientes multiplican su base de usuarios sin quemar presupuesto en marketing.",
  },
];
---

<section class="landing-section">
  <SectionHeader
    title="Resultados que mueven"
    subtitle="tu negocio hacia adelante"
    align="center"
    tag="Impacto"
  />
  <!-- Bento Grid -->
  <div
    data-stagger="150"
    class="gap-4 grid grid-cols-[repeat(auto-fit,minmax(250px,1fr))] w-full"
  >
    {
      stats.map((stat) => (
        <StatCard
          number={stat.number}
          label={stat.label}
          description={stat.description}
        />
      ))
    }
  </div>
</section>
