---
import { copy } from "~/lib/copy";

const { whyUs } = copy;
---

<section id="why-us" class="py-32 px-6 bg-neutral-50 dark:bg-neutral-900">
  <div class="max-w-5xl mx-auto space-y-16">
    <!-- Header -->
    <h2
      class="text-4xl md:text-6xl font-bold text-neutral-900 dark:text-neutral-50"
    >
      {whyUs.title}
    </h2>

    <!-- Headline -->
    <div class="text-center space-y-4">
      {
        whyUs.headline.map((line) => (
          <p class="text-3xl md:text-5xl font-bold text-neutral-900 dark:text-neutral-50">
            {line}
          </p>
        ))
      }
      <div class="pt-6">
        <span
          class="text-6xl md:text-8xl font-bold text-neutral-900 dark:text-neutral-50"
        >
          {whyUs.badge}
        </span>
      </div>
    </div>

    <!-- Points grid -->
    <ul class="grid md:grid-cols-2 gap-6 pt-8">
      {
        whyUs.points.map((point) => (
          <li class="flex items-start gap-4 p-6 rounded-2xl bg-white dark:bg-neutral-800 border border-neutral-200 dark:border-neutral-700 hover:border-neutral-900 dark:hover:border-neutral-50 transition-all duration-300">
            <svg
              class="flex-shrink-0 w-6 h-6 mt-1 text-neutral-900 dark:text-neutral-50"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M13 10V3L4 14h7v7l9-11h-7z"
              />
            </svg>
            <span class="text-lg md:text-xl text-neutral-700 dark:text-neutral-300">
              {point}
            </span>
          </li>
        ))
      }
    </ul>

    <!-- Footer -->
    <div class="text-center pt-12 space-y-2 border-t border-neutral-200 dark:border-neutral-800">
      {
        whyUs.footer.map((line) => (
          <p class="text-2xl md:text-3xl font-bold text-neutral-900 dark:text-neutral-50">
            {line}
          </p>
        ))
      }
    </div>
  </div>
</section>

