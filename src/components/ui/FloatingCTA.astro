---
/**
 * FloatingCTA - CTA flotante que aparece al hacer scroll
 * Mejora conversión mostrando CTA siempre visible
 */
---

<div
  id="floating-cta"
  class="fixed bottom-6 right-6 z-50 opacity-0 translate-y-4 transition-all duration-300 pointer-events-none"
>
  <a
    href="/contact"
    class="flex items-center gap-3 px-6 py-4 bg-primary text-background rounded-full shadow-2xl hover:shadow-primary/50 hover:scale-105 transition-all duration-300 pointer-events-auto group"
  >
    <span class="font-semibold">Hablemos de tu proyecto</span>
    <svg
      class="size-5 group-hover:translate-x-1 transition-transform"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M17 8l4 4m0 0l-4 4m4-4H3"></path>
    </svg>
  </a>
</div>

<script>
  // Mostrar CTA flotante después de scroll
  let lastScroll = 0;
  const floatingCTA = document.getElementById("floating-cta");

  if (floatingCTA) {
    window.addEventListener("scroll", () => {
      const currentScroll = window.scrollY;

      // Mostrar después de 500px de scroll y cuando se hace scroll hacia abajo
      if (currentScroll > 500 && currentScroll > lastScroll) {
        floatingCTA.classList.remove("opacity-0", "translate-y-4");
        floatingCTA.classList.add("opacity-100", "translate-y-0");
      } else if (currentScroll < 300) {
        floatingCTA.classList.add("opacity-0", "translate-y-4");
        floatingCTA.classList.remove("opacity-100", "translate-y-0");
      }

      lastScroll = currentScroll;
    });
  }
</script>
