---
import SectionTag from "./SectionTag.astro";

interface Props {
  tag?: string;
  title: string;
  subtitle?: string;
  description?: string;
  linkText?: string;
  linkHref?: string;
  align?: "left" | "center";
}

const {
  tag,
  title,
  subtitle,
  description,
  linkText,
  linkHref,
  align = "left",
} = Astro.props;

const aligns = {
  center: "text-center mx-auto items-center",
  left: "text-left items-start",
};

const alignClass = aligns[align] || "";
---

<header class:list={["flex justify-between gap-6 w-full"]}>
  <div class={`flex flex-col gap-4 max-w-2xl ${alignClass}`}>
    {tag && <SectionTag>{tag}</SectionTag>}

    <div
      class:list={[
        "max-w-2xl mx-auto flex-col text-3xl md:text-4xl font-semibold",
        alignClass,
      ]}
    >
      <h2>{title}</h2>
      {subtitle && <p class="text-muted-foreground">{subtitle}</p>}
    </div>
    {
      description && (
        <p
          class="text-base text-[#50576b] dark:text-neutral-400"
          style="letter-spacing: -0.02em;"
        >
          {description}
        </p>
      )
    }
  </div>
  {
    linkText && linkHref && (
      <a
        href={linkHref}
        class="hidden md:inline-flex items-center gap-2 text-sm font-medium text-[#0f1115] dark:text-neutral-50 hover:opacity-70 transition-opacity"
        style="letter-spacing: -0.02em;"
      >
        {linkText}
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M17 8l4 4m0 0l-4 4m4-4H3"
          />
        </svg>
      </a>
    )
  }
</header>
