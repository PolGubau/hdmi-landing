---
import UpRightArrow from "./UpRightArrow.astro";

interface Props {
  id: string;
  title: string;
  summary: string;
  category: string;
  color: string;
  tech?: string[];
}

const { id, title, category, color } = Astro.props;
---

<a href={`/proyectos/${id}`} class="w-full">
  <article
    class="group h-full flex flex-col gap-4 rounded-4xl bg-accent shadow-pastel overflow-hidden transition-all duration-300 p-3"
  >
    <header class="w-full aspect-[1.5] rounded-2xl overflow-hidden">
      <!-- Image placeholder -->
      <div
        class="group-hover:scale-110 transition-all w-full h-full bg-gradient-to-br from-neutral-200 to-neutral-300 flex items-center justify-center relative"
        style={`background: linear-gradient(135deg, ${color}20, ${color}40)`}
      >
        <div class="absolute inset-0 flex items-center justify-center">
          <span class="text-6xl font-bold opacity-10" style={`color: ${color}`}>
            {title.charAt(0)}
          </span>
        </div>
      </div>
    </header>

    <footer class="flex items-center gap-4 justify-between px-2 pb-2">
      <div class="flex flex-col gap-1">
        <span class="text-xs text-muted-foreground">
          {category}
        </span>
        <h3 class="text-xl font-semibold">
          {title}
        </h3>
      </div>

      <div>
        <UpRightArrow class="bg-background duration-300 p-2" />
      </div>
    </footer>
  </article>
</a>
