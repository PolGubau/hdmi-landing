---
import { Image } from "astro:assets";
import type { Project } from "~/content.config";
import UpRightArrow from "./UpRightArrow.astro";

type ProjectProps = Pick<
  Project,
  "title" | "summary" | "services_provided" | "color" | "cover"
>;

type Props = {
  id: string;
} & ProjectProps;

const { id, title, services_provided, cover } = Astro.props;
---

<a href={`/projects/${id}`} class="w-full">
  <article
    class="group h-full flex flex-col gap-4 rounded-4xl bg-accent shadow-pastel overflow-x-hidden transition-all duration-300 p-3"
  >
    <header class="w-full aspect-[1.5] rounded-3xl overflow-hidden">
      <!-- Image -->
      <div
        class="group-hover:scale-102 duration-300 transition-all w-full h-full bg-gradient-to-br from-muted to-primary/20 flex items-center justify-center relative overflow-hidden"
      >
        <Image
          width={800}
          height={500}
          src={cover}
          alt={`Imagen de portada del proyecto ${title}, mostrando una vista previa visual del trabajo realizado para el cliente. La imagen refleja el estilo y la esencia del proyecto, utilizando colores y elementos gráficos relacionados con ${title}.`}
          class="w-full h-full object-cover object-center"
        />
      </div>
    </header>

    <footer class="flex items-center gap-4 justify-between px-2 pb-2">
      <div class="flex flex-col gap-1">
        <span class="text-xs text-muted-foreground">
          {
            services_provided?.length > 0 &&
              services_provided.map((cat) => cat.trim()).join(" · ")
          }
        </span>
        <h3 class="text-xl font-semibold">
          {title}
        </h3>
      </div>

      <div>
        <UpRightArrow class="bg-background duration-300 p-2" />
      </div>
    </footer>
  </article>
</a>
