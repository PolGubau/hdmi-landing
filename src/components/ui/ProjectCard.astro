---
interface Props {
  id: string;
  title: string;
  summary: string;
  category: string;
  color: string;
  tech?: string[];
}

const { id, title, category, color } = Astro.props;
---

<a href={`/proyectos/${id}`} class="shrink-0 w-[320px] md:w-[550px]">
  <article
    class="group h-full flex flex-col gap-4 rounded-4xl bg-accent shadow-pastel overflow-hidden transition-all duration-300 p-3"
  >
    <header class="w-full aspect-[1.49733] rounded-2xl overflow-hidden">
      <!-- Image placeholder -->
      <div
        class="group-hover:scale-110 w-full h-full bg-gradient-to-br from-neutral-200 to-neutral-300 flex items-center justify-center relative"
        style={`background: linear-gradient(135deg, ${color}20, ${color}40)`}
      >
        <div class="absolute inset-0 flex items-center justify-center">
          <span class="text-6xl font-bold opacity-10" style={`color: ${color}`}>
            {title.charAt(0)}
          </span>
        </div>
      </div>
    </header>

    <div class="flex flex-col gap-1 px-2 pb-2">
      <h3 class="text-xl font-semibold">
        {title}
      </h3>

      <span class="text-xs text-muted-foreground">
        {category}
      </span>
    </div>
  </article>
</a>
