---
import ClientsMarquee from "./ClientsMarquee.astro";
import { type Client, clients as defaultClients } from "./clients.ts";

type Props = {
  clients?: Client[];
};

const { clients = defaultClients } = Astro.props;
---

<div class="relative overflow-hidden">
  <div
    class="absolute left-0 top-0 bottom-0 w-48 md:w-64 bg-gradient-to-r from-background via-background/80 z-10 pointer-events-none"
  >
  </div>
  <div
    class="absolute right-0 top-0 bottom-0 w-48 md:w-64 bg-gradient-to-l from-background via-background/80 z-10 pointer-events-none"
  >
  </div>

  <!-- Scrolling content -->
  <div class="flex gap-16 animate-scroll pb-10">
    <ClientsMarquee clients={clients} />
    <ClientsMarquee clients={clients} />
  </div>
</div>

<style>
  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .animate-scroll {
    animation: scroll 30s linear infinite;
  }

  .animate-scroll:hover {
    animation-play-state: paused;
  }
</style>
