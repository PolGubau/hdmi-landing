---
import { getProjects } from "~/shared/lib/collections";
import ClientsMarquee from "./ClientsMarquee.astro";

// Obtener todos los proyectos con logo
const allProjects = await getProjects();
const projectsWithLogo = allProjects.filter((project) => project.data.logo);
---

<!-- Wrapper que se adapta al contenedor padre -->
<div class="marquee-wrapper">
  <!-- Contenedor con overflow y posición relativa -->
  <div class="marquee-container">
    <!-- Degradados que se adaptan al contenedor -->
    <div class="marquee-fade marquee-fade-left"></div>
    <div class="marquee-fade marquee-fade-right"></div>

    <!-- Scrolling content -->
    <div class="marquee-content">
      <ClientsMarquee projects={projectsWithLogo} />
      <ClientsMarquee projects={projectsWithLogo} />
    </div>
  </div>
</div>

<style>
  /* Wrapper que toma el ancho del contenedor padre */
  .marquee-wrapper {
    width: 100%;
    position: relative;
  }

  /* Contenedor con overflow hidden */
  .marquee-container {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  /* Degradados que se adaptan al contenedor */
  .marquee-fade {
    position: absolute;
    top: 0;
    bottom: 0;
    width: clamp(80px, 15vw, 200px); /* Responsive width */
    z-index: 10;
    pointer-events: none;
  }

  .marquee-fade-left {
    left: 0;
    background: linear-gradient(
      to right,
      hsl(var(--background)) 0%,
      hsl(var(--background) / 0.9) 40%,
      hsl(var(--background) / 0.5) 70%,
      transparent 100%
    );
  }

  .marquee-fade-right {
    right: 0;
    background: linear-gradient(
      to left,
      hsl(var(--background)) 0%,
      hsl(var(--background) / 0.9) 40%,
      hsl(var(--background) / 0.5) 70%,
      transparent 100%
    );
  }

  /* Contenido que se desplaza */
  .marquee-content {
    display: flex;
    gap: 4rem;
    padding-bottom: 2.5rem;
    animation: scroll 30s linear infinite;
    will-change: transform;
  }

  /* Animación de scroll */
  @keyframes scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  /* Velocidad en móvil */
  @media (max-width: 768px) {
    .marquee-content {
      animation-duration: 20s;
      gap: 2rem;
    }
  }

  /* Pausa al hover */
  .marquee-content:hover {
    animation-play-state: paused;
  }
</style>
