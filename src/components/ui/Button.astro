---
import { cn } from "~/shared/lib/utils";
import UpRightArrow from "./UpRightArrow.astro";
export type ButtonProps = {
  size?: "sm" | "md" | "lg";
  variant?: "solid" | "outline";
  class?: string;
  withArrow?: boolean;
  type?: "button" | "submit" | "reset";
};

type Props = ButtonProps;

const {
  class: className = "",
  size = "md",
  variant = "solid",
  withArrow = false,
  type = "button",
  ...rest
} = Astro.props;
---

<button
  data-size={size}
  type={type}
  class={cn(
    "group gap-2 text-center justify-center transition-all rounded-full w-fit flex items-center select-none focus:outline-none ring-2 ring-transparent focus:ring-primary",
    {
      "text-background bg-foreground hover:shadow-xl active:shadow-lg hover:bg-foreground/90 shadow-pastel-sm":
        variant === "solid",
      "text-foreground bg-transparent border-2 border-muted hover:border-muted-foreground active:border-foreground hover:bg-foreground/5 active:bg-foreground/10":
        variant === "outline",
      "py-1 px-3 text-sm": size === "sm",
      "px-5 py-2.5 text-base": size === "md",
      "py-3 text-lg px-5": size === "lg",
      "pr-1": withArrow && size === "sm",
      "pr-3": withArrow && size === "md",
      "pr-5": withArrow && size === "lg",
    },
    className,
  )}
  {...rest}
>
  <slot />
  {withArrow && <UpRightArrow />}
</button>
