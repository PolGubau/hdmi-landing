---
import { cn } from "~/shared/lib/utils";
import UpRightArrow from "./UpRightArrow.astro";
export type ButtonProps = {
  size?: "sm" | "md" | "lg";
  class?: string;
  withArrow?: boolean;
  type?: "button" | "submit" | "reset";
};

type Props = ButtonProps;

const {
  class: className = "",
  size = "md",
  withArrow = false,
  type = "button",
  ...rest
} = Astro.props;
---

<button
  data-size={size}
  type={type}
  class={cn(
    "group text-background gap-2 p-2.5 text-center justify-center transition-all rounded-full w-fit flex items-center bg-foreground select-none hover:shadow-xl active:shadow-lg hover:bg-foreground/90 shadow-pastel-sm",
    "focus:outline-none ring-2 ring-transparent focus:ring-primary",
    {
      "py-1 px-3 text-sm": size === "sm",
      "px-5 py-2.5 text-base": size === "md",
      "p-3 text-lg": size === "lg",

      "pr-1": withArrow && size === "sm",
      "pr-3": withArrow && size === "md",
      "pr-5": withArrow && size === "lg",
    },
    className,
  )}
  {...rest}
>
  <slot />
  {withArrow && <UpRightArrow />}
</button>
