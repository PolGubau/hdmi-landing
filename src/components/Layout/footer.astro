---
import NewsletterInput from "~/components/ui/NewsletterInput";
import { branding } from "~/config/branding";
import { copy } from "~/shared/lib/copy";
import FinalCTA from "../sections/FinalCTA.astro";

const currentYear = new Date().getFullYear();

const footerLinks = {
  producto: [
    { label: "Inicio", href: "/" },
    { label: "Proyectos", href: "/projects" },
    { label: "Blog", href: "/blog" },
    { label: "Sobre nosotros", href: "/sobre-nosotros" },
  ],
  legal: [
    { label: "Aviso Legal", href: "/legal" },
    { label: "Privacidad", href: "/privacy" },
    { label: "Cookies", href: "/cookies" },
  ],
  social: [
    { label: "LinkedIn", href: branding.social.linkedin },
    { label: "Twitter", href: branding.social.twitter },
    { label: "GitHub", href: branding.social.github },
  ],
};
---

<section class="bg-foreground text-background">
  <div class="bg-background rounded-b-[5vw] py-16">
    <FinalCTA />
  </div>

  <footer class="bg-foreground text-background py-20 px-6">
    <div class="max-w-7xl mx-auto">
      <!-- Main footer content -->
      <div class="grid md:grid-cols-2 lg:grid-cols-12 gap-12">
        <!-- Brand & Newsletter (takes more space) -->
        <div class="lg:col-span-6 space-y-8">
          <div class="space-y-4">
            <h3 class="text-3xl font-semibold">
              {branding.name}
            </h3>
            <p class="text-muted text-lg max-w-md">
              {copy.footer.tagline}
            </p>
            <div class="flex flex-col gap-2 pt-2">
              <a
                href="mailto:hola@doscientos.es"
                class="text-neutral-300 hover:text-white transition-colors text-sm flex items-center gap-2"
              >
                <span>✉</span> hola@doscientos.es
              </a>
              <a
                href="tel:+34671171525"
                class="text-neutral-300 hover:text-white transition-colors text-sm flex items-center gap-2"
              >
                <span>📞</span> +34 671 171 525
              </a>
            </div>
          </div>

          <div class="space-y-4">
            <h4
              class="text-sm font-medium text-background uppercase tracking-wider"
            >
              Newsletter
            </h4>
            <p class="text-muted text-sm max-w-md text-balance">
              Recibe actualizaciones sobre modernización de sistemas y mejores
              prácticas técnicas.
            </p>
            <NewsletterInput
              client:load
              className="placeholder:text-muted/60 bg-accent/10 text-muted"
            />
          </div>
        </div>

        <!-- Links columns -->
        <div class="lg:col-span-2 space-y-6">
          <h4
            class="text-sm font-medium text-background uppercase tracking-wider"
          >
            Producto
          </h4>
          <ul class="space-y-3">
            {
              footerLinks.producto.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-neutral-300 hover:text-neutral-50 transition-colors"
                    style="letter-spacing: -0.02em;"
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="lg:col-span-2 space-y-6">
          <h4
            class="text-sm font-medium text-background uppercase tracking-wider"
          >
            Legal
          </h4>
          <ul class="space-y-3">
            {
              footerLinks.legal.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-neutral-300 hover:text-neutral-50 transition-colors"
                    style="letter-spacing: -0.02em;"
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
        <div class="lg:col-span-2 space-y-6">
          <h4
            class="text-sm font-medium text-background uppercase tracking-wider"
          >
            Social
          </h4>
          <ul class="space-y-3">
            {
              footerLinks.social.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-neutral-300 hover:text-neutral-50 transition-colors"
                    style="letter-spacing: -0.02em;"
                  >
                    {link.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
      </div>

      <!-- Bottom bar -->
      <div
        class="pt-20 flex flex-col md:flex-row justify-between items-center gap-6"
      >
        <p class="text-sm text-muted">
          {copy.footer.copyright.replace("2026", currentYear.toString())}
        </p>
        <a
          href="https://g.page/r/CVVDrT1qq_qvEBM/review"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-sm text-neutral-300 hover:text-white transition-colors group"
        >
          <span class="flex text-yellow-400 text-base leading-none">★★★★★</span>
          <span>Déjanos una reseña en Google</span>
        </a>
      </div>
    </div>
  </footer>
</section>
