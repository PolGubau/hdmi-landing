---
/**
 * Google Analytics 4 (GA4)
 * Analytics gratuito de Google
 */

const GA_MEASUREMENT_ID = import.meta.env.PUBLIC_GA_MEASUREMENT_ID;
const isDev = import.meta.env.DEV;

// No cargar analytics en desarrollo
if (isDev) {
  console.log("📊 Google Analytics disabled in development");
}
---

{!isDev && GA_MEASUREMENT_ID && (
  <>
    <!-- Preconnect para cargar más rápido cuando se otorgue consent -->
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="dns-prefetch" href="https://www.googletagmanager.com" />

    <!-- GA4: solo se inicializa si hay consent de analytics -->
    <script is:inline define:vars={{ GA_MEASUREMENT_ID }}>
      window.GA_MEASUREMENT_ID_PENDING = GA_MEASUREMENT_ID;
      if (window.__DOS_CONSENT?.analytics) {
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', GA_MEASUREMENT_ID, { page_path: window.location.pathname });
        var s = document.createElement('script');
        s.async = true;
        s.src = 'https://www.googletagmanager.com/gtag/js?id=' + GA_MEASUREMENT_ID;
        document.head.appendChild(s);
      }
    </script>
  </>
)}
