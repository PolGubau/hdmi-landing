---
import { getProjects } from "~/shared/lib/collections";
import ProjectsRail from "./ProjectsRail.astro";
import SectionHeader from "~/components/ui/SectionHeader.astro";

type Props = {
  currentProjectId: string;
};

const { currentProjectId } = Astro.props;

const projects = await getProjects();
const otherProjects = projects
  .filter((p) => p.id !== currentProjectId)
  .slice(0, 4);
---

<div class="bg-muted/50">
  <section class="px-6 max-w-7xl mx-auto space-y-16 py-16 w-full">
    <SectionHeader
      title="Más proyectos"
      description="Echa un vistazo a algunos de nuestros otros proyectos destacados."
    />
    <ProjectsRail projects={otherProjects} />
  </section>
</div>
