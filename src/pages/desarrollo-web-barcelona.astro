---
import Button from "~/components/ui/Button.astro";
import SectionHeader from "~/components/ui/SectionHeader.astro";
import SectionTag from "~/components/ui/SectionTag.astro";
import StatCard from "~/components/ui/StatCard.astro";
import MainLayout from "~/layouts/MainLayout.astro";
import { getProjects } from "~/shared/lib/collections";

const barcelonaProjects = await getProjects(3);

const stats = [
  {
    number: "500+",
    label: "Usuarios conseguidos sin ads",
    description: "Empresas de Barcelona generando tracción orgánica desde el primer día.",
  },
  {
    number: "-90%",
    label: "Reducción en tiempo de procesos",
    description: "Automatizaciones que generan ROI real en empresas barcelonesas.",
  },
  {
    number: "6 sem",
    label: "De idea a producto",
    description: "Lanzamos MVPs validados con usuarios reales en Barcelona.",
  },
];

const benefits = [
  {
    title: "Reuniones presenciales en Barcelona",
    description: "Nos reunimos contigo en persona para entender tu proyecto a fondo.",
  },
  {
    title: "Conocimiento del mercado local",
    description: "Entendemos el ecosistema startup y empresarial de Barcelona.",
  },
  {
    title: "Soporte en tu zona horaria",
    description: "Respuesta rápida en horario laboral español.",
  },
];
---

<MainLayout
  title="Desarrollo Web Barcelona - MVPs en 6 semanas | doscientos"
  description="Agencia de desarrollo web en Barcelona. Lanzamos MVPs en 6 semanas. Automatizaciones con ROI real. 500+ usuarios sin ads. Reuniones presenciales."
>
  <section class="px-6 max-w-7xl mx-auto pt-32 space-y-24">
    <!-- Hero -->
    <header class="max-w-3xl mx-auto text-center space-y-8" data-stagger="100">
      <div data-reveal="top" data-speed="fast" data-easing="smooth">
        <SectionTag>Barcelona</SectionTag>
      </div>
      
      <h1
        class="text-4xl md:text-6xl font-bold text-foreground"
        data-reveal="scale"
        data-speed="normal"
        data-easing="bounce"
      >
        Desarrollo Web en Barcelona
        <span class="block text-primary mt-2">De idea a producto en 6 semanas</span>
      </h1>

      <p
        class="text-xl text-muted-foreground max-w-2xl mx-auto"
        data-reveal="bottom"
        data-speed="normal"
        data-easing="soft"
      >
        Somos una agencia de desarrollo web en Barcelona especializada en lanzar MVPs rápidos,
        automatizar procesos y modernizar sistemas críticos. Sin quemar presupuesto.
      </p>

      <div
        class="flex flex-col sm:flex-row gap-4 justify-center items-center"
        data-reveal="scale"
        data-speed="fast"
        data-easing="elastic"
      >
        <a href="/contact">
          <Button size="lg" withArrow>Agendar reunión en Barcelona</Button>
        </a>
        <a href="/projects">
          <Button size="lg" variant="outline">Ver proyectos</Button>
        </a>
      </div>
    </header>

    <!-- Stats -->
    <div class="grid md:grid-cols-3 gap-6" data-stagger="150">
      {stats.map((stat) => (
        <StatCard
          number={stat.number}
          label={stat.label}
          description={stat.description}
        />
      ))}
    </div>

    <!-- Por qué Barcelona -->
    <section class="space-y-12">
      <SectionHeader
        tag="Local"
        title="Por qué trabajar con una agencia"
        subtitle="de Barcelona"
        description="Entendemos el ecosistema local y trabajamos codo a codo contigo."
        align="center"
      />

      <div class="grid md:grid-cols-3 gap-8" data-stagger="100">
        {benefits.map((benefit) => (
          <div
            class="p-8 rounded-2xl bg-accent space-y-4"
            data-reveal="bottom"
            data-speed="normal"
            data-easing="soft"
          >
            <h3 class="text-xl font-semibold text-foreground">{benefit.title}</h3>
            <p class="text-muted-foreground">{benefit.description}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Casos de éxito -->
    <section class="space-y-12">
      <SectionHeader
        tag="Proyectos"
        title="Empresas de Barcelona"
        subtitle="que confiaron en nosotros"
        description="Casos de éxito reales con resultados medibles."
        align="center"
      />

      <div class="grid md:grid-cols-3 gap-6">
        {barcelonaProjects.map((project) => (
          <a
            href={`/projects/${project.id}`}
            class="group block p-6 rounded-2xl bg-accent hover:bg-muted transition-colors"
          >
            <h3 class="text-xl font-semibold text-foreground group-hover:text-primary transition-colors">
              {project.data.title}
            </h3>
            <p class="text-muted-foreground mt-2">{project.data.summary}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- CTA Final -->
    <section class="bg-primary text-background rounded-3xl p-12 text-center space-y-6">
      <h2 class="text-3xl md:text-4xl font-bold">
        ¿Listo para lanzar tu proyecto en Barcelona?
      </h2>
      <p class="text-xl opacity-90 max-w-2xl mx-auto">
        Agenda una reunión presencial o videollamada. Sin compromiso, sin presión.
      </p>
      <a href="/contact">
        <Button size="lg" class="bg-background text-primary hover:bg-background/90">
          Agendar reunión →
        </Button>
      </a>
    </section>
  </section>
</MainLayout>

