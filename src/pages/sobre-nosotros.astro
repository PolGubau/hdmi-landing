---
import { Image } from "astro:assets";
import { CircleCheck } from "@lucide/astro";
import Button from "~/components/ui/Button.astro";
import SectionHeader from "~/components/ui/SectionHeader.astro";
import { branding } from "~/config/branding";
import MainLayout from "~/layouts/MainLayout.astro";

import gerardImg from "~/assets/media/branding/team/gerard.webp";
import polImg from "~/assets/media/branding/team/pol.webp";
import team1Img from "~/assets/media/branding/team/team1.webp";
import team12Img from "~/assets/media/branding/team/team2.webp";

const values = [
  {
    title: "Experiencia desde el primer día",
    description:
      "Cada proyecto lo lideran ingenieros con más de 5 años de experiencia en producto. Tu proyecto merece esa atención.",
  },
  {
    title: "Precio cerrado desde el día 1",
    description:
      "Presupuesto fijo antes de empezar. Sin sorpresas, sin horas extra, sin facturas inesperadas al final del mes.",
  },
  {
    title: "Entrega en 6 semanas",
    description:
      "Metodología probada que nos permite lanzar productos digitales funcionales en seis semanas o menos.",
  },
  {
    title: "Código que escala",
    description:
      "Construimos sobre tecnologías modernas y arquitecturas limpias. Tu producto crece contigo, no te frena.",
  },
];

// Images are static imports (required by Astro Image); metadata comes from branding.ts
const teamImages = [polImg, gerardImg];
const team = branding.team.map((member, i) => ({
  ...member,
  image: teamImages[i],
}));

const baseUrl = "https://doscientos.es";
const personSchemas = branding.team.map((member) => ({
  "@context": "https://schema.org",
  "@type": "Person",
  name: member.name,
  jobTitle: member.role,
  description: member.bio,
  url: member.link,
  worksFor: {
    "@type": "Organization",
    name: branding.name,
    url: baseUrl,
  },
  sameAs: [member.link],
}));
---

<MainLayout
  title="Sobre nosotros | doscientos, agencia de desarrollo web en Barcelona"
  description="doscientos es una agencia de desarrollo web y automatización en Barcelona formada por ingenieros con más de 5 años de experiencia en producto. Precio cerrado y entrega en 6 semanas."
>
  {
    personSchemas.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))
  }
  <!-- Hero -->
  <section class="px-6 max-w-7xl mx-auto pt-28 lg:pt-36">
    <div class="max-w-3xl" data-reveal="bottom">
      <span
        class="inline-flex items-center gap-2 text-sm font-medium text-primary bg-primary/10 px-4 py-1.5 rounded-full mb-6"
      >
        Sobre nosotros
      </span>
      <h1
        class="text-4xl lg:text-6xl font-bold text-foreground leading-tight mb-6"
      >
        Agencia de desarrollo web en Barcelona<br />
        <span class="text-primary">con experiencia real en producto</span>
      </h1>
      <p class="text-xl text-muted-foreground leading-relaxed max-w-2xl">
        Somos un equipo pequeño y deliberadamente así. En doscientos, cada
        proyecto lo lidera alguien con años de experiencia real en producto.
        Trabajamos con empresas que quieren resultados concretos, no promesas
        vagas.
      </p>
    </div>
  </section>

  <!-- Team photo -->
  <section class="px-6 max-w-7xl mx-auto">
    <div class="grid md:grid-cols-2 gap-4" data-reveal="bottom">
      <!-- Photo 1: Pol -->
      <div class="relative group">
        <Image
          src={team1Img}
          alt="Pol Gubau, co-fundador de doscientos"
          class="w-full h-96 lg:h-[480px] object-cover rounded-2xl"
          loading="eager"
        />
        <!-- Figma cursor: Pol -->
        <div
          class="absolute bottom-22 left-18 flex items-start gap-0 pointer-events-none select-none animate-float-pol"
        >
          <svg
            width="18"
            height="22"
            viewBox="0 0 18 22"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            class="drop-shadow-md shrink-0"
          >
            <path
              d="M0.5 0.5L0.5 17.5L4.5 13.5L7.5 20.5L10 19.5L7 12.5H12.5L0.5 0.5Z"
              fill="#6366f1"
              stroke="white"
              stroke-width="1"></path>
          </svg>
          <span
            class="ml-1 mt-3 bg-indigo-500 text-white text-sm font-semibold px-2.5 py-1 rounded-full rounded-tl-none shadow-lg whitespace-nowrap"
          >
            {branding.team[0].name}
          </span>
        </div>
      </div>

      <!-- Photo 2: Gerard -->
      <div class="relative group">
        <Image
          src={team12Img}
          alt="Gerard, co-fundador de doscientos"
          class="w-full h-96 lg:h-[480px] object-cover rounded-2xl"
          loading="eager"
        />
        <!-- Figma cursor: Gerard -->
        <div
          class="absolute bottom-10 -right-4 flex items-start gap-0 pointer-events-none select-none animate-float-gerard"
        >
          <svg
            width="18"
            height="22"
            viewBox="0 0 18 22"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            class="drop-shadow-md shrink-0"
          >
            <path
              d="M0.5 0.5L0.5 17.5L4.5 13.5L7.5 20.5L10 19.5L7 12.5H12.5L0.5 0.5Z"
              fill="#ec4899"
              stroke="white"
              stroke-width="1"></path>
          </svg>
          <span
            class="ml-1 mt-3 bg-pink-500 text-white text-sm font-semibold px-2.5 py-1 rounded-full rounded-tl-none shadow-lg whitespace-nowrap"
          >
            {branding.team[1].name}
          </span>
        </div>
      </div>
    </div>
  </section>

  <style>
    @keyframes float-pol {
      0%,
      100% {
        transform: translate(0, 0) rotate(-2deg);
      }
      50% {
        transform: translate(3px, -6px) rotate(0deg);
      }
    }
    @keyframes float-gerard {
      0%,
      100% {
        transform: translate(0, 0) rotate(1deg);
      }
      50% {
        transform: translate(-3px, -5px) rotate(-1deg);
      }
    }
    .animate-float-pol {
      animation: float-pol 4s ease-in-out infinite;
    }
    .animate-float-gerard {
      animation: float-gerard 4.5s ease-in-out infinite 0.8s;
    }
  </style>

  <!-- Mission -->
  <section class="px-6 md:px-10 max-w-7xl mx-auto">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <div data-reveal="left">
        <SectionHeader
          tag="Nuestra misión"
          title="Hacer que la tecnología trabaje para ti, no al revés"
          description="Muchas agencias alargan los proyectos porque su modelo de negocio depende de las horas facturadas. El nuestro no: precio fijo, equipo experimentado y un plazo que cumplimos."
        />
        <ul class="mt-8 space-y-4">
          {
            values.map((v) => (
              <li class="flex gap-3">
                <CircleCheck class="size-5 text-primary shrink-0 mt-0.5" />
                <div>
                  <p class="font-semibold text-foreground">{v.title}</p>
                  <p class="text-sm text-muted-foreground max-w-md text-balance">
                    {v.description}
                  </p>
                </div>
              </li>
            ))
          }
        </ul>
      </div>
      <div class="space-y-6" data-reveal="right">
        <div class="bg-accent rounded-2xl p-8 space-y-6">
          <p class="text-2xl font-semibold text-foreground leading-snug">
            "Fundamos doscientos porque vimos que las PYMEs merecen el mismo
            nivel de software que las grandes empresas, sin los plazos ni los
            precios desorbitados."
          </p>
          <p class="text-muted-foreground text-sm">
            - Pol & Gerard, cofundadores
          </p>
        </div>
        <div class="grid grid-cols-3 gap-4 text-center">
          <div class="bg-accent rounded-xl p-4">
            <p class="text-3xl font-bold text-primary">+30</p>
            <p class="text-xs text-muted-foreground mt-1">
              proyectos entregados
            </p>
          </div>
          <div class="bg-accent rounded-xl p-4">
            <p class="text-3xl font-bold text-primary">6 sem</p>
            <p class="text-xs text-muted-foreground mt-1">
              plazo medio de entrega
            </p>
          </div>
          <div class="bg-accent rounded-xl p-4">
            <p class="text-3xl font-bold text-primary">100%</p>
            <p class="text-xs text-muted-foreground mt-1">precio cerrado</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="px-6 max-w-7xl mx-auto">
    <SectionHeader
      tag="El equipo"
      title="Las personas detrás de cada proyecto"
      description="No somos una gran agencia. Somos dos ingenieros que se implican personalmente en cada proyecto que aceptamos."
    />
    <div class="grid md:grid-cols-2 gap-8 mt-12">
      {
        team.map((member) => (
          <article
            class="group bg-accent rounded-2xl overflow-hidden"
            data-reveal="bottom"
          >
            <div class="aspect-[4/3] overflow-hidden">
              <Image
                src={member.image}
                alt={`${member.name}, ${member.role}`}
                class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
              />
            </div>
            <div class="p-6 space-y-3">
              <div>
                <h3 class="text-xl font-bold text-foreground">{member.name}</h3>
                <p class="text-sm text-primary font-medium">{member.role}</p>
              </div>
              <p class="text-muted-foreground text-sm leading-relaxed">
                {member.bio}
              </p>
              <a
                href={member.link}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-2 text-sm font-medium text-primary hover:underline"
              >
                Ver más →
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </section>

  <!-- CTA -->
  <section class="px-6 max-w-7xl mx-auto pb-20">
    <div
      class="bg-foreground text-background rounded-3xl p-10 lg:p-16 flex flex-col lg:flex-row items-center justify-between gap-8"
      data-reveal="bottom"
    >
      <div class="space-y-3 max-w-xl">
        <h2 class="text-3xl lg:text-4xl font-bold">
          ¿Quieres trabajar con nosotros?
        </h2>
        <p class="text-neutral-400 text-lg">
          Cuéntanos tu proyecto. En 24 horas te respondemos con un enfoque y una
          estimación de coste.
        </p>
      </div>
      <a href="/contact">
        <Button size="lg" withArrow>Hablemos</Button>
      </a>
    </div>
  </section>
</MainLayout>
