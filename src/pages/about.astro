---
import SectionHeader from "~/components/ui/SectionHeader.astro";
import MainLayout from "~/layouts/MainLayout.astro";

const values = [
  {
    icon: "⚡",
    title: "Velocidad sin sacrificar calidad",
    description:
      "Entregamos rápido, pero nunca a costa de la calidad. Cada línea de código está pensada para durar.",
  },
  {
    icon: "🎯",
    title: "Enfoque en resultados",
    description:
      "No vendemos horas, vendemos soluciones. Nos importa que tu negocio crezca, no solo que el código funcione.",
  },
  {
    icon: "🔒",
    title: "Cero interrupciones",
    description:
      "Modernizamos tu sistema sin detener tu negocio. Migraciones seguras, probadas y reversibles.",
  },
  {
    icon: "🤝",
    title: "Transparencia total",
    description:
      "Sin sorpresas. Comunicación clara, presupuestos fijos y entregas predecibles.",
  },
];
---

<MainLayout
  title="Nosotros | doscientos"
  description="Conoce al equipo detrás de doscientos. Expertos en modernización de sistemas críticos."
>
  <div class="min-h-screen py-20 px-6">
    <div class="max-w-7xl mx-auto space-y-32">
      <!-- Header -->
      <div class="text-center max-w-3xl mx-auto">
        <SectionHeader
          tag="Nosotros"
          title="Modernizamos sistemas sin romper nada"
          description="Somos un equipo de ingenieros especializados en llevar sistemas legacy a tecnologías modernas. Sin reescrituras completas, sin interrupciones, sin dramas."
          align="center"
        />
      </div>

      <!-- Story -->
      <div class="max-w-4xl mx-auto space-y-8">
        <h2 class="text-3xl md:text-4xl font-semibold text-foreground">
          Nuestra historia
        </h2>
        <div class="space-y-6 text-lg text-muted-foreground leading-relaxed">
          <p>
            Después de años trabajando en proyectos de modernización para
            empresas de todos los tamaños, nos dimos cuenta de un patrón: la
            mayoría de los equipos técnicos cometen los mismos errores.
          </p>
          <p>
            Reescrituras completas que nunca terminan. Migraciones que rompen
            todo. Consultores que cobran por hora sin entregar resultados.
          </p>
          <p>
            Decidimos hacer las cosas diferente. Creamos un método probado que
            permite modernizar sistemas críticos sin detener el negocio, sin
            reescribir desde cero, y con resultados medibles desde el primer
            día.
          </p>
          <p class="font-semibold text-foreground">
            Así nació doscientos: 200 líneas de código bien escritas valen más
            que 2000 líneas de código legacy.
          </p>
        </div>
      </div>

      <!-- Values -->
      <div class="space-y-12">
        <div class="text-center max-w-2xl mx-auto">
          <h2 class="text-3xl md:text-4xl font-semibold text-foreground mb-4">
            Nuestros valores
          </h2>
          <p class="text-lg text-muted-foreground">
            Lo que nos define y guía cada decisión que tomamos.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8">
          {
            values.map((value) => (
              <div class="p-8 rounded-2xl bg-accent border border-neutral-200 dark:border-neutral-800 space-y-4">
                <div class="text-4xl">{value.icon}</div>
                <h3 class="text-2xl font-semibold text-foreground">
                  {value.title}
                </h3>
                <p class="text-muted-foreground leading-relaxed">
                  {value.description}
                </p>
              </div>
            ))
          }
        </div>
      </div>

      <!-- Stats -->
      <div class="grid md:grid-cols-3 gap-8 py-12">
        <div class="text-center space-y-2">
          <div class="text-5xl font-bold text-foreground">+20</div>
          <div class="text-muted-foreground">Proyectos completados</div>
        </div>
        <div class="text-center space-y-2">
          <div class="text-5xl font-bold text-foreground">100%</div>
          <div class="text-muted-foreground">Sin interrupciones</div>
        </div>
        <div class="text-center space-y-2">
          <div class="text-5xl font-bold text-foreground">0</div>
          <div class="text-muted-foreground">Reescrituras completas</div>
        </div>
      </div>

      <!-- CTA -->
      <div
        class="p-12 rounded-2xl bg-primary text-background text-center space-y-6"
      >
        <h3 class="text-3xl md:text-4xl font-semibold">
          ¿Listo para modernizar tu sistema?
        </h3>
        <p class="text-xl opacity-90 max-w-2xl mx-auto">
          Agenda una llamada de 30 minutos y descubre cómo podemos ayudarte.
        </p>
        <a
          href="/contact"
          class="inline-block px-8 py-4 bg-background text-primary rounded-xl font-semibold hover:opacity-90 transition-opacity"
        >
          Contactar
        </a>
      </div>
    </div>
  </div>
</MainLayout>
