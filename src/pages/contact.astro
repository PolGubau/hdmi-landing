---
import { Icon } from "astro-icon/components";
import ContactForm from "~/components/forms/ContactForm";
import Button from "~/components/ui/Button.astro";
import SectionHeader from "~/components/ui/SectionHeader.astro";
import MainLayout from "~/layouts/MainLayout.astro";

const calendlyUrl = "https://calendly.com/hola-doscientos-0jch/30min";
---

<MainLayout

  description="Agenda una llamada o envíanos un mensaje. Estamos aquí para ayudarte a modernizar tu sistema."
>
  <section class="px-6 max-w-7xl mx-auto lg:pt-36">
    <div
      class="grid lg:grid-cols-2 gap-10 lg:gap-20 max-lg:divide-y lg:divide-x divide-muted"
    >
      <!-- Option 1: Calendly -->
      <article class="space-y-20 max-lg:pb-10 lg:pr-20">
        <SectionHeader
          tag="Contacto"
          title="Hablemos de tu proyecto"
          description="Tanto si estás listo para empezar como si solo tienes dudas, estamos aquí para ayudarte."
        />

        <div>
          <header class="space-y-4">
            <h3 class="text-2xl font-semibold text-foreground">
              Agenda una llamada
            </h3>
            <p class="text-muted-foreground leading-relaxed max-w-md">
              Elige el día y hora que mejor te convenga. Hablaremos de tu
              proyecto y cómo podemos ayudarte.
            </p>
          </header>

          <ul class="space-y-2 py-6 text-sm text-muted-foreground">
            <li class="flex items-center gap-2">
              <Icon name="sparkle" class="size-5 text-primary" />
              En 15 minutos analizamos tu proyecto
            </li>
            <li class="flex items-center gap-2">
              <Icon name="sparkle" class="size-5 text-primary" />
              Sin compromiso
            </li>
            <li class="flex items-center gap-2">
              <Icon name="sparkle" class="size-5 text-primary" />
              Respuesta inmediata
            </li>
          </ul>
          <a href={calendlyUrl} target="_blank" rel="noopener noreferrer">
            <Button withArrow> Agendar llamada </Button>
          </a>
        </div>
      </article>

      <!-- Option 2: Contact Form -->
      <article class="space-y-6">
        <div class="space-y-4">
          <div
            class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center"
          >
            <svg
              class="w-6 h-6 text-primary"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
          </div>
          <h3 class="text-2xl font-semibold text-foreground">
            Envíanos un mensaje
          </h3>
          <p class="text-muted-foreground leading-relaxed">
            Cuéntanos sobre tu proyecto y te contactaremos en menos de 24 horas.
          </p>
        </div>

        <ContactForm client:load />
      </article>
    </div>
  </section>
</MainLayout>
