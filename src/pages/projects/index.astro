---
import ProjectCard from "~/components/ui/ProjectCard.astro";
import SectionTag from "~/components/ui/SectionTag.astro";
import MainLayout from "~/layouts/MainLayout.astro";
import { getProjects } from "~/shared/lib/collections";

const projects = await getProjects();
---

<MainLayout
  title="Proyectos - 21+ casos de éxito | doscientos"
  description="500+ usuarios sin ads. ROI del 300% en 4 meses. -90% tiempo en procesos. Descubre cómo ayudamos a empresas como la tuya a crecer con productos digitales."
>
  <div class="min-h-screen py-24 px-6">
    <div class="max-w-7xl mx-auto space-y-16">
      <!-- Header -->
      <header
        class="flex flex-col max-w-2xl items-center justify-center text-center gap-6 mx-auto"
        data-stagger="100"
      >
        <div data-reveal="top" data-speed="fast" data-easing="smooth">
          <SectionTag>Proyectos</SectionTag>
        </div>
        <h1
          class="font-semibold text-foreground flex flex-col text-3xl md:text-5xl items-center text-center"
          data-reveal="scale"
          data-speed="normal"
          data-easing="bounce"
        >
          <span>Cómo ayudamos a crecer a </span>
          <span class="text-muted-foreground">otras empresas.</span>
        </h1>
        <p
          class="text-muted-foreground max-w-md text-pretty"
          data-reveal="bottom"
          data-speed="normal"
          data-easing="soft"
          data-distance="small"
        >
          Casos de éxito en modernización de sistemas críticos. Proyectos
          reales, resultados medibles, cero interrupciones.
        </p>
      </header>

      <!-- Stats -->
      <ul class="grid md:grid-cols-4 gap-4" data-stagger="100">
        <li
          class="p-6 rounded-2xl bg-muted"
          data-reveal="scale"
          data-speed="normal"
          data-easing="bounce"
        >
          <span class="text-4xl font-bold text-foreground">
            {projects.length + 17}+
          </span>
          <h3 class="text-muted-foreground">Proyectos completados</h3>
        </li>
        <li
          class="p-6 rounded-2xl bg-muted"
          data-reveal="scale"
          data-speed="normal"
          data-easing="bounce"
        >
          <span class="text-4xl font-bold text-foreground">100%</span>
          <h3 class="text-muted-foreground">Sin interrupciones</h3>
        </li>
        <li
          class="p-6 rounded-2xl bg-muted"
          data-reveal="scale"
          data-speed="normal"
          data-easing="bounce"
        >
          <span class="text-4xl font-bold text-foreground">7+</span>
          <h3 class="text-muted-foreground">Años de experiencia</h3>
        </li>
        <li
          class="p-6 rounded-2xl bg-muted"
          data-reveal="scale"
          data-speed="normal"
          data-easing="bounce"
        >
          <span class="text-4xl font-bold text-foreground">99.9%</span>
          <h3 class="text-muted-foreground">Uptime promedio</h3>
        </li>
      </ul>

      <h2
        class="text-3xl md:text-4xl font-bold text-foreground text-center"
        data-reveal="bottom"
        data-speed="normal"
        data-easing="soft"
        data-distance="small"
      >
        Casos de éxito destacados
      </h2>

      <!-- Projects grid -->
      <section class="grid lg:grid-cols-2 gap-4" data-stagger="150">
        {
          projects.map((project, index) => (
            <article
              class="group"
              data-reveal={index % 2 === 0 ? "left" : "right"}
              data-speed="normal"
              data-easing="smooth"
            >
              <a href={`/projects/${project.id}`}>
                <ProjectCard
                  id={project.id}
                  title={project.data.title}
                  summary={project.data.summary}
                  services_provided={project.data.services_provided}
                  color={project.data.color}
                  cover={project.data.cover}
                />
              </a>
            </article>
          ))
        }
      </section>
    </div>
  </div>
</MainLayout>
