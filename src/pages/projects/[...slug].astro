---
import { Image } from "astro:assets";
import { getCollection, render } from "astro:content";
import { Layout, Timer, User } from "@lucide/astro";
import Breadcrumbs from "~/components/seo/Breadcrumbs.astro";
import SchemaOrg from "~/components/seo/SchemaOrg.astro";
import Highlight from "~/components/ui/Highlight.astro";
import Link from "~/components/ui/Link.astro";
import OtherProjects from "~/features/projects/ui/OtherProjects.astro";
import MainLayout from "~/layouts/MainLayout.astro";

export async function getStaticPaths() {
  const projects = await getCollection(
    "projects",
    ({ data }) => data.available,
  );
  return projects.map((project) => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

// Obtener la URL de la imagen de cover para OG
const coverImage = project.data.cover;
const publishedTime =
  project.data.endedAt instanceof Date
    ? project.data.endedAt.toISOString()
    : project.data.endedAt;
---

<MainLayout
  title={`${project.data.title} | Proyectos`}
  description={project.data.summary}
  image={coverImage?.src}
  type="article"
  article={{
    publishedTime,
    author: "doscientos",
    tags: project.data.services_provided,
  }}
>
  <SchemaOrg
    type="project"
    project={{
      name: project.data.title,
      description: project.data.summary,
      image: coverImage?.src,
      client: project.data.client,
      datePublished: publishedTime,
      url: `https://doscientos.es/projects/${project.id}`,
    }}
  />
  <article
    class="min-h-screen py-4 lg:py-20 px-4 lg:px-6 max-w-5xl mx-auto space-y-6 lg:space-y-12"
  >
    <!-- Breadcrumbs para SEO -->
    <Breadcrumbs
      className="pl-4"
      items={[
        { name: "Proyectos", url: "/projects" },
        { name: project.data.title, url: `/projects/${project.id}` },
      ]}
    />

    <header class="space-y-6 border mb-20 border-muted p-6 lg:p-8 rounded-5xl">
      <div class="flex flex-col gap-4 pb-4 p-2">
        <h1 class="text-4xl md:text-5xl font-bold text-foreground">
          {project.data.title}
        </h1>

        <p class="text-muted-foreground text-pretty max-w-lg">
          {project.data.summary}
        </p>

        {
          project.data.link && (
            <div class="border border-muted p-2 pl-3 w-fit rounded-full">
              <Link href={project.data.link} label="Visitar sitio web" />
            </div>
          )
        }
      </div>
      <div
        class="w-full rounded-4xl object-cover overflow-hidden aspect-video bg-muted"
      >
        <Image
          src={project.data.cover}
          alt={project.data.title}
          width={1200}
          height={600}
          class="object-cover w-full h-full rounded-4xl aspect-video bg-muted"
        />
      </div>
      <ul class="grid lg:grid-cols-3 gap-4 items-center">
        <Highlight label="Cliente" value={project.data.client}>
          <User class="size-5 text-muted-foreground" />
        </Highlight>
        <Highlight
          label="Servicios ofrecidos"
          value={project.data.services_provided?.join(", ")}
        >
          <Layout class="size-5 text-muted-foreground" />
        </Highlight>
        <Highlight label="Timeline" value={`${project.data.timeline} semanas`}>
          <Timer class="size-5 text-muted-foreground" />
        </Highlight>
      </ul>
    </header>

    <div
      class="px-2
      prose prose-neutral prose-sm mx-auto w-full max-w-none
      
      prose-p:max-w-xl prose-p:mx-auto
      prose-ul:max-w-xl prose-ul:mx-auto
      prose-blockquote:max-w-xl prose-blockquote:mx-auto
      
        prose-headings:font-bold prose-headings:text-foreground
        prose-h2:text-3xl prose-h2:mt-12 prose-h2:mb-6
        prose-h3:text-2xl prose-h3:mt-8 prose-h3:mb-4
        prose-h4:text-xl prose-h4:mt-6 prose-h4:mb-3
        prose-p:text-muted-foreground
        prose-p:leading-relaxed
        prose-a:text-foreground
        prose-a:underline
        hover:prose-a:no-underline
        prose-strong:text-foreground
        prose-ul:text-muted-foreground
        prose-ol:text-muted-foreground
        prose-li:marker:text-neutral-500
        prose-blockquote:border-l-4
        prose-blockquote:border-neutral-300
        prose-blockquote:italic
        prose-blockquote:text-neutral-600
        prose-code:text-foreground
        prose-pre:bg-foreground"
    >
      <Content />
    </div>
  </article>
  <OtherProjects currentProjectId={project.id} />
</MainLayout>
