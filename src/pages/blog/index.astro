---
import { getCollection } from "astro:content";
import NewsletterInput from "~/components/ui/NewsletterInput";
import SectionTag from "~/components/ui/SectionTag.astro";
import MainLayout from "~/layouts/MainLayout.astro";

const blogPosts = await getCollection("blog", ({ data }) => !data.draft);
const sortedPosts = blogPosts.sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime(),
);
---

<MainLayout
  title="Blog | doscientos"
  description="Artículos sobre modernización de sistemas, arquitectura de software y mejores prácticas técnicas."
>
  <div class="min-h-screen py-32 px-6">
    <div class="max-w-6xl mx-auto space-y-16">
      <header
        class="flex flex-col max-w-2xl items-center justify-center text-center gap-6 mx-auto"
      >
        <SectionTag>Nuestro blog</SectionTag>
        <h1
          class="font-semibold text-foreground flex flex-col text-3xl md:text-5xl items-center text-center"
        >
          <span>Últimos artículos del equipo</span>
        </h1>
        <p class="text-muted-foreground max-w-md text-pretty">
          Sigue al día con ideas sobre diseño, desarrollo y nuevas tecnologías
          que generan impacto real.
        </p>
        <NewsletterInput client:load />
      </header>

      <!-- Posts grid -->
      {
        sortedPosts.length > 0 ? (
          <div class="grid md:grid-cols-2 gap-6">
            {sortedPosts.map((post) => (
              <article class="group">
                <a
                  href={`/blog/${post.id}`}
                  class="flex flex-col h-full p-6 rounded-2xl gap-2 shadow-pastel border border-muted bg-accent hover:border-primary transition-colors"
                >
                  {/* Date */}
                  <time class="text-sm text-muted-foreground mb-2">
                    {post.data.publishDate.toLocaleDateString("es-ES", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </time>

                  {/* Title */}
                  <h2 class="text-2xl font-bold text-foreground transition-colors">
                    {post.data.title}
                  </h2>

                  {/* Description */}
                  <p class="text-muted-foreground line-clamp-3">
                    {post.data.description}
                  </p>

                  {/* Tags */}
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-2 pt-2">
                      {post.data.tags.map((tag) => (
                        <span class="text-xs px-3 py-1 rounded-full bg-muted text-foreground">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}

                  {/* Read more */}
                  <div class="flex items-center gap-2 text-foreground font-medium pt-2">
                    Leer más
                    <svg
                      class="w-4 h-4 group-hover:translate-x-1 transition-transform"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M17 8l4 4m0 0l-4 4m4-4H3"
                      />
                    </svg>
                  </div>
                </a>
              </article>
            ))}
          </div>
        ) : (
          <div class="text-center py-20">
            <p class="text-xl text-neutral-500 dark:text-neutral-400">
              Próximamente publicaremos artículos técnicos.
            </p>
          </div>
        )
      }
    </div>
  </div>
</MainLayout>
