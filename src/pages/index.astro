---
import MainLayout from "~/layouts/MainLayout.astro";

import CaseStudies from "~/components/sections/CaseStudies.astro";
import FAQ from "~/components/sections/FAQ.astro";
import Hero from "~/components/sections/Hero.astro";
import Impact from "~/components/sections/Impact.astro";
import Method from "~/components/sections/Method.astro";
import Services from "~/components/sections/Services.astro";
import Testimonials from "~/components/sections/Testimonials.astro";
import Hype from "~/components/sections/Hype.astro";

const title = "doscientos - Desarrollo Web y Producto Digital en Barcelona";
const description =
    "Agencia de desarrollo web especializada en diseño, SEO, branding y motion design. Transformamos ideas en productos digitales de alto rendimiento. Barcelona, España.";
---

<MainLayout title={title} description={description}>
    <Hero />
    <Impact />
    <Services />
    <CaseStudies />
    <Testimonials />
    <Method />
    <FAQ />
    <Hype />
</MainLayout>
