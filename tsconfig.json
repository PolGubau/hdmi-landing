{
	"extends": "astro/tsconfigs/strict",
	"include": [".astro/types.d.ts", "**/*"],
	"exclude": ["dist", "node_modules", "public", "src/assets", "src/content"],
	"compilerOptions": {
		"strictNullChecks": true,
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"baseUrl": ".",
		"paths": {
			"~/*": ["./src/*"]
		},
		
		"skipLibCheck": true,
		"incremental": true
	}
}
